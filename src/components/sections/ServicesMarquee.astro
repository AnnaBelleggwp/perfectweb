---
const services = [
	{
		id: 'design',
		label: 'веб-дизайн',
		desc: 'проектирую интерфейсы с нуля — от вайрфреймов до финального ui. фокус на визуальной иерархии, читаемости и деталях которые замечают не сразу.',
		items: ['ui/ux дизайн', 'figma', 'прототипирование', 'дизайн-система', 'адаптив'],
	},
	{
		id: 'dev',
		label: 'разработка',
		desc: 'верстаю и собираю сайты на современном стеке. код чистый, компоненты переиспользуемые, производительность на первом месте.',
		items: ['astro', 'react', 'typescript', 'tailwind', 'seo'],
	},
	{
		id: 'motion',
		label: 'анимация',
		desc: 'добавляю движение которое усиливает смысл, а не отвлекает. scroll-триггеры, микровзаимодействия, плавные переходы между состояниями.',
		items: ['gsap', 'scroll-анимации', 'lenis', 'svg-анимация', 'микровзаимодействия'],
	},
	{
		id: 'webflow',
		label: 'webflow',
		desc: 'собираю сайты в webflow с полноценными анимациями и cms. заказчик редактирует контент сам — без разработчика и без риска сломать верстку.',
		items: ['webflow cms', 'interactions', 'e-commerce', 'интеграции', 'обучение'],
	},
];
---

<section id="services-a" class="section-anchor sma-section">
	<p class="eyebrow">услуги — вариант а</p>

	<div class="sma-marquee-wrap" aria-hidden="true">
		<div class="sma-marquee-track">
			{[...services, ...services].map(s => (
				<span class="sma-marquee-item">
					{s.label}<span class="sma-sep">✦</span>
				</span>
			))}
		</div>
	</div>

	<div class="sma-nav" role="tablist">
		{services.map((s, i) => (
			<button
				class:list={['sma-tab', { 'is-active': i === 0 }]}
				role="tab"
				data-id={s.id}
				aria-selected={i === 0 ? 'true' : 'false'}
			>
				{s.label}
			</button>
		))}
	</div>

	<div class="sma-cards">
		{services.map((s, i) => (
			<article
				class:list={['sma-card', { 'sma-card--active': i === 0 }]}
				data-card={s.id}
			>
				<p class="sma-card-name">{s.label}</p>
				<p class="sma-card-desc">{s.desc}</p>
				<div class="sma-tags">
					{s.items.map(item => <span class="sma-tag">{item}</span>)}
				</div>
			</article>
		))}
	</div>
</section>

<style>
.sma-section {
	display: flex;
	flex-direction: column;
	gap: clamp(1rem, 2vw, 1.5rem);
}

/* ── Marquee ── */
.sma-marquee-wrap {
	overflow: hidden;
	border-top: 1px solid rgba(255, 215, 0, 0.18);
	border-bottom: 1px solid rgba(255, 215, 0, 0.18);
	padding: 0.55rem 0;
}

.sma-marquee-track {
	display: flex;
	width: max-content;
	animation: sma-scroll 26s linear infinite;
}

@keyframes sma-scroll {
	from { transform: translateX(0); }
	to   { transform: translateX(-50%); }
}

.sma-marquee-item {
	font-size: clamp(1.2rem, 2.2vw, 1.6rem);
	font-weight: 300;
	color: var(--color-text-muted);
	white-space: nowrap;
	display: flex;
	align-items: center;
}

.sma-sep {
	color: var(--color-accent);
	margin: 0 1.25rem;
	font-size: 0.72em;
	opacity: 0.55;
}

/* ── Tab nav ── */
.sma-nav {
	display: flex;
	flex-wrap: wrap;
	gap: 0.45rem;
}

.sma-tab {
	padding: 0.32rem 0.9rem;
	font-size: clamp(0.95rem, 1.6vw, 1.1rem);
	font-family: var(--font-sans);
	font-weight: 300;
	border: 1px solid rgba(255, 255, 255, 0.14);
	border-radius: 999px;
	background: rgba(255, 255, 255, 0.04);
	color: var(--color-text-muted);
	cursor: pointer;
	transition: border-color 180ms ease, color 180ms ease, background 180ms ease;
}

.sma-tab:hover,
.sma-tab.is-active {
	border-color: rgba(255, 215, 0, 0.45);
	color: var(--color-accent);
	background: rgba(255, 215, 0, 0.07);
}

/* ── Cards — CSS grid overlay trick ── */
.sma-cards {
	display: grid;
}

.sma-card {
	grid-area: 1 / 1;
	opacity: 0;
	pointer-events: none;
	background: rgba(255, 255, 255, 0.04);
	backdrop-filter: blur(2px);
	-webkit-backdrop-filter: blur(2px);
	border: 1px solid rgba(255, 255, 255, 0.14);
	border-radius: var(--radius-card);
	box-shadow:
		inset 0 1px 0 rgba(255, 255, 255, 0.18),
		0 8px 32px rgba(0, 0, 0, 0.28);
	padding: var(--section-padding);
	display: flex;
	flex-direction: column;
	gap: clamp(0.75rem, 1.5vw, 1.25rem);
}

.sma-card--active {
	opacity: 1;
	pointer-events: auto;
}

.sma-card-name {
	margin: 0;
	font-size: clamp(1.9rem, 4.2vw, 3rem);
	font-weight: 300;
	line-height: 0.94;
	color: var(--color-accent);
}

.sma-card-desc {
	margin: 0;
	font-size: clamp(1.1rem, 2vw, 1.4rem);
	font-weight: 300;
	line-height: 1.22;
	color: var(--color-text-muted);
	max-width: 68ch;
}

.sma-tags {
	display: flex;
	flex-wrap: wrap;
	gap: 0.45rem;
	margin-top: auto;
	padding-top: clamp(0.5rem, 1vw, 0.75rem);
}

.sma-tag {
	padding: 0.28rem 0.7rem;
	font-size: clamp(0.9rem, 1.4vw, 1rem);
	border: 1px solid rgba(255, 215, 0, 0.28);
	border-radius: 999px;
	color: var(--color-accent);
	background: rgba(255, 215, 0, 0.05);
}

@media (prefers-reduced-motion: reduce) {
	.sma-marquee-track { animation: none; }
}
</style>

<script>
import gsap from 'gsap';

const section = document.querySelector<HTMLElement>('#services-a');
if (section) {
	const tabs  = section.querySelectorAll<HTMLButtonElement>('.sma-tab');
	const cards = section.querySelectorAll<HTMLElement>('.sma-card');

	let active = section.querySelector<HTMLElement>('.sma-card--active');
	if (active) gsap.set(active, { opacity: 1 });

	const switchTo = (id: string) => {
		const next = section.querySelector<HTMLElement>(`[data-card="${id}"]`);
		if (!next || next === active) return;

		const prev = active;
		active = next;

		if (prev) {
			gsap.to(prev, {
				opacity: 0,
				y: -10,
				duration: 0.2,
				ease: 'power2.in',
				onComplete: () => {
					prev.classList.remove('sma-card--active');
					(prev as HTMLElement).style.pointerEvents = 'none';
					gsap.set(prev, { y: 0 });
				},
			});
		}

		gsap.delayedCall(0.18, () => {
			next.classList.add('sma-card--active');
			(next as HTMLElement).style.pointerEvents = 'auto';
			gsap.fromTo(next, { opacity: 0, y: 12 }, { opacity: 1, y: 0, duration: 0.28, ease: 'power2.out' });
		});
	};

	tabs.forEach(tab => {
		tab.addEventListener('click', () => {
			tabs.forEach(t => { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
			tab.classList.add('is-active');
			tab.setAttribute('aria-selected', 'true');
			switchTo(tab.dataset.id ?? '');
		});
	});
}
</script>
