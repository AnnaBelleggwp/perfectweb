---
---

<section id="hero" class="section-anchor hero-section">
	<div class="hero-dots" data-hero-dots aria-hidden="true"></div>
	<div class="hero-body">
		<div class="hero-content">
			<div class="hero-copy">
				<p class="eyebrow hero-eyebrow"></p>
				<h1 class="hero-title hero-title--empty"></h1>
				<p class="body-copy hero-desc"></p>
			</div>
			<div class="hero-actions">
				<a
					class="hero-link"
					href="#contact"
					data-hover-fill
					data-label="обсудить проект"
				>
					обсудить проект
				</a>
				<span class="hero-scroll-cue" aria-hidden="true">
				<span class="hero-scroll-cue__desktop">просто листай</span>
				<span class="hero-scroll-cue__mobile">нажми на паутину что бы познать больше. а потом просто листай</span>
			</span>
			</div>
		</div>
	</div>
</section>

<style>
.hero-section {
	flex: 1;
	min-height: 0;
	display: flex;
	flex-direction: column;
	padding-inline: clamp(1.2rem, 4vw, 3rem);
	padding-top: clamp(0.7rem, 2.4svh, 3rem);
	padding-bottom: 10px;
	position: relative;
	isolation: isolate;
}

.hero-dots {
	position: absolute;
	top: 0;
	bottom: 0;
	left: 50%;
	width: 100vw;
	transform: translateX(-50%);
	pointer-events: none;
	z-index: 0;
}

.hero-dots :global(.dot-grid__canvas) {
	position: absolute;
	inset: 0;
	width: 100%;
	height: 100%;
	display: block;
}

.hero-body {
	flex: 1;
	display: flex;
	min-height: 0;
	position: relative;
	z-index: 1;
}

.hero-content {
	width: 100%;
	display: grid;
	grid-template-rows: minmax(0, 1fr) auto;
	flex: 1;
	min-height: 0;
}

.hero-copy {
	display: flex;
	flex-direction: column;
	min-height: 0;
	overflow: hidden;
	gap: clamp(1rem, 2.5vw, 1.75rem);
}

.hero-eyebrow {
	min-height: min(1.5em, 4svh);
}

.hero-title--empty {
	min-height: min(calc(0.88 * clamp(2.3rem, 7vw, 5.75rem) * 3), 34svh);
}

.hero-desc {
	min-height: min(calc(1.15 * clamp(1.15rem, 2.3vw, 1.55rem) * 2), 14svh);
}

.hero-actions {
	position: absolute;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	z-index: 2;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 0.4rem;
}

.hero-link {
	--hero-fill-size: 0px;
	--hero-fill-target: 220px;
	--hero-fill-x: 50%;
	--hero-fill-y: 50%;
	position: relative;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	font-size: clamp(2.6rem, 5.6vw, 4.5rem);
	font-weight: 300;
	color: var(--color-text);
	white-space: nowrap;
	transition: color 180ms ease;
}

.hero-scroll-cue {
	font-size: clamp(1.05rem, 1.6vw, 1.3rem);
	font-weight: 300;
	color: color-mix(in srgb, var(--color-text) 55%, transparent);
	letter-spacing: 0.04em;
	user-select: none;
	text-align: center;
	max-width: min(36ch, 86vw);
	line-height: 1.3;
}

.hero-scroll-cue__mobile {
	display: none;
}

.hero-scroll-cue__desktop {
	display: inline;
}

.hero-link:hover,
.hero-link:focus-visible {
	outline: none;
}

.hero-link::after {
	content: attr(data-label);
	position: absolute;
	inset: 0;
	color: var(--color-accent);
	white-space: nowrap;
	pointer-events: none;
	mask-image: radial-gradient(
		circle var(--hero-fill-size) at var(--hero-fill-x) var(--hero-fill-y),
		#000 96%,
		transparent 100%
	);
	-webkit-mask-image: radial-gradient(
		circle var(--hero-fill-size) at var(--hero-fill-x) var(--hero-fill-y),
		#000 96%,
		transparent 100%
	);
	transition: --hero-fill-size 680ms cubic-bezier(0.22, 0.8, 0.24, 1);
}

.hero-link.is-hovered::after {
	--hero-fill-size: var(--hero-fill-target);
}

@property --hero-fill-size {
	syntax: '<length>';
	inherits: false;
	initial-value: 0px;
}

@media (prefers-reduced-motion: reduce) {
	.hero-link { animation: none; }

	.hero-link::after {
		transition: none;
	}
}

@media (max-width: 767px) {
	.hero-actions {
		padding-bottom: clamp(0.6rem, 2.6vh, 1rem);
	}

	.hero-scroll-cue__desktop {
		display: none;
	}

	.hero-scroll-cue__mobile {
		display: inline;
	}
}
</style>

<script>
	import { initDotGrid } from '../../scripts/dot-grid';

	const dotsWrap = document.querySelector<HTMLElement>('[data-hero-dots]');
	if (dotsWrap) {
		initDotGrid(dotsWrap, {
			dotSize: 4,
			gap: 22,
			trimCornerDots: false,
			proximity: 140,
			shockRadius: 220,
			shockStrength: 4,
		});
	}

	const links = document.querySelectorAll('[data-hover-fill]');

	links.forEach((link) => {
		link.addEventListener('pointerenter', (event) => {
			const pointerEvent = event;
			const rect = link.getBoundingClientRect();
			const localX = Math.max(0, Math.min(rect.width, pointerEvent.clientX - rect.left));
			const localY = Math.max(0, Math.min(rect.height, pointerEvent.clientY - rect.top));
			const x = (localX / rect.width) * 100;
			const y = (localY / rect.height) * 100;
			const corners = [
				{ x: 0, y: 0 },
				{ x: rect.width, y: 0 },
				{ x: 0, y: rect.height },
				{ x: rect.width, y: rect.height },
			];
			const maxRadius = Math.max(
				...corners.map((corner) =>
					Math.hypot(corner.x - localX, corner.y - localY),
				),
			);

			link.style.setProperty('--hero-fill-x', `${Math.max(0, Math.min(100, x))}%`);
			link.style.setProperty('--hero-fill-y', `${Math.max(0, Math.min(100, y))}%`);
			link.style.setProperty('--hero-fill-target', `${Math.ceil(maxRadius + 8)}px`);
			link.classList.add('is-hovered');
		});

		link.addEventListener('pointerleave', () => {
			link.classList.remove('is-hovered');
		});
	});

	// ── Scramble / decrypt cycler on hero CTA ───────────────────
	const heroLink = document.querySelector<HTMLAnchorElement>('.hero-link');
	if (heroLink) {
		const phrases = ['обсудить проект', 'обсудить дизайн', 'обсудить что-угодно'];
		const POOL = 'абвгдежзийклмнопрстуфхцчшщъыьэюя0123456789#@$%&*<>/=+-';
		const HOLD_MS = 4800;
		const DURATION_MS = 600;
		const FRAMES = Math.round(DURATION_MS / 16);

		const randChar = () => POOL.charAt(Math.floor(Math.random() * POOL.length));
		const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		let activeIdx = 0;
		let stopped = false;

		const scrambleTo = (target: string): Promise<void> => new Promise((resolve) => {
			if (prefersReduced) {
				heroLink.textContent = target;
				heroLink.dataset.label = target;
				return resolve();
			}
			const previous = (heroLink.textContent ?? '').trim();
			const maxLen = Math.max(previous.length, target.length);
			const settle: number[] = [];
			for (let i = 0; i < maxLen; i++) {
				const base = Math.floor((i / Math.max(1, maxLen)) * FRAMES * 0.55);
				const jitter = Math.floor(Math.random() * (FRAMES * 0.5));
				settle.push(base + jitter);
			}
			const last = Math.max(...settle);

			let frame = 0;
			const tick = () => {
				if (stopped) return resolve();
				let out = '';
				for (let i = 0; i < maxLen; i++) {
					out += frame >= settle[i] ? (target[i] ?? '') : randChar();
				}
				heroLink.textContent = out;
				heroLink.dataset.label = out;
				frame++;
				if (frame > last + 1) {
					heroLink.textContent = target;
					heroLink.dataset.label = target;
					return resolve();
				}
				requestAnimationFrame(tick);
			};
			requestAnimationFrame(tick);
		});

		const loop = async () => {
			while (!stopped) {
				await new Promise((r) => setTimeout(r, HOLD_MS));
				if (stopped) break;
				activeIdx = (activeIdx + 1) % phrases.length;
				await scrambleTo(phrases[activeIdx]);
			}
		};
		void loop();
	}
</script>
