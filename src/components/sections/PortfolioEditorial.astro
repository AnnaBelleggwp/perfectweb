---
import { DEFAULT_SITE_CONTENT, type PortfolioItem } from '../../data/site-content';

interface Props {
	portfolio?: PortfolioItem[];
}

const { portfolio = DEFAULT_SITE_CONTENT.portfolio } = Astro.props;
const items = (portfolio.length ? portfolio : DEFAULT_SITE_CONTENT.portfolio).filter((p) => p.published);

const isPlaceholder = (item: PortfolioItem) => /ваш(?:е)?\s+будущ/i.test(item.title);
const isTemplateCard = (item: PortfolioItem) =>
	isPlaceholder(item) || /^название\s/i.test(item.title);

const categories = ['все проекты', ...new Set(items.map((p) => p.category))];


---

<section id="portfolio" class="section-anchor pf-section">
	<div class="pf-shell site-shell">

		<!-- ── Header ──────────────────────────────────────── -->
		<div class="pf-head">
			<div class="pf-head__mark">
				<span class="section-mark pf-reveal">мои работы</span>
			</div>
			<h2 class="pf-title pf-reveal">отобранные проекты,</h2>
			<p class="pf-subtitle pf-reveal">
				в которых идея,<br />
				технологии и визуал работают как единое целое.
			</p>
		</div>

		<!-- ── Divider ─────────────────────────────────────── -->
		<div class="pf-divider pf-reveal" aria-hidden="true"></div>

		<!-- ── Filters ─────────────────────────────────────── -->
		<nav class="pf-filters pf-reveal" aria-label="фильтр проектов">
			{categories.map((cat, i) => (
				<button
					type="button"
					class:list={['pf-chip', { 'is-active': i === 0 }]}
					data-filter={i === 0 ? 'all' : cat}
				>
					<span class="pf-chip__dot" aria-hidden="true"></span>
					{cat}
				</button>
			))}
		</nav>

		<!-- ── Project carousel deck ───────────────────────── -->
		<div class="pf-stage" data-pf-stage>
			<button
				type="button"
				class="pf-nav pf-nav--prev"
				data-pf-prev
				aria-label="предыдущий проект"
			>
				<svg width="22" height="22" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</button>

			<div class="pf-deck" data-pf-deck>
				{items.map((item, idx) => {
					const num = String(idx + 1).padStart(2, '0');
					const isTpl = isTemplateCard(item);

					return (
						<article
							class:list={['pf-card3d', isTpl ? 'is-template' : 'is-filled']}
							data-pf-card
							data-category={item.category}
							data-index={idx}
							aria-hidden={idx === 0 ? 'false' : 'true'}
							tabindex={idx === 0 ? 0 : -1}
						>
							<div class="pf-card3d__top">
								<div class="pf-card3d__num" aria-hidden="true">
									<span>{isTpl ? '?' : num}</span>
								</div>
								<div class="pf-card3d__id">
									{isTpl ? (
										<>
											<p class="pf-card3d__title">
												<span class="pf-sym">{`{`}</span> name <span class="pf-sym">{`}`}</span>
											</p>
											<p class="pf-card3d__cat">
												<span class="pf-sym">{`<`}</span>category<span class="pf-sym">{` />`}</span>
											</p>
										</>
									) : (
										<>
											<p class="pf-card3d__title">{item.title}</p>
											<p class="pf-card3d__cat">{item.category}</p>
										</>
									)}
								</div>
								<div class="pf-card3d__year">{isTpl ? '____' : item.year}</div>
							</div>

							<blockquote class="pf-card3d__body">
								{isTpl ? (
									<>
										<p><span class="pf-sym">//</span> project.description</p>
										<p><span class="pf-sym">//</span> ─ ─ ─ <span class="pf-caret" aria-hidden="true">_</span></p>
									</>
								) : (
									item.description ? (
										<p>{item.description}</p>
									) : (
										<p class="pf-card3d__body--empty"><span class="pf-sym">//</span> описание скоро</p>
									)
								)}
							</blockquote>

							<footer class="pf-card3d__foot">
								<span class="pf-card3d__tags">
									{isTpl ? (
										<><span class="pf-sym">[</span> tags <span class="pf-sym">]</span></>
									) : (
										item.tags.slice(0, 3).join(' · ')
									)}
								</span>
								<span class="pf-card3d__dot" aria-hidden="true">•</span>
								{isTpl ? (
									<a href="#contact" class="pf-card3d__cta">обсудить</a>
								) : (
									<a href={item.caseUrl} class="pf-card3d__cta">смотреть →</a>
								)}
							</footer>
						</article>
					);
				})}
			</div>

			<button
				type="button"
				class="pf-nav pf-nav--next"
				data-pf-next
				aria-label="следующий проект"
			>
				<svg width="22" height="22" viewBox="0 0 16 16" fill="none" aria-hidden="true">
					<path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</button>
		</div>

		<!-- ── Bottom bar ──────────────────────────────────── -->
		<div class="pf-bottom pf-reveal">
			<a href="#contact" class="pf-bottom__cta" data-hover-fill data-label="обсудить проект">
				обсудить проект
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
					<path d="M1 13L13 1M13 1H5M13 1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</a>
			<p class="pf-counter" data-pf-counter>
				<span data-pf-cur>01</span>
				<span class="pf-counter__sep">/</span>
				<span data-pf-total>01</span>
			</p>
		</div>

	</div>
</section>

<style>
/* ══════════════════════════════════════════════════════
   Portfolio Editorial Grid
   ══════════════════════════════════════════════════════ */

.pf-section {
	padding: clamp(2rem, 5vw, 4rem) 0;
	overflow: hidden;
}

/* ── Header ─────────────────────────────────────────── */
.pf-head {
	display: flex;
	flex-direction: column;
	gap: clamp(0.4rem, 1vw, 0.75rem);
}

.pf-head__mark {
	display: flex;
	align-items: center;
	gap: 0.75rem;
}

.pf-title {
	margin: 0;
	font-size: clamp(2.4rem, 5.4vw, 4.5rem);
	font-weight: 300;
	line-height: 0.95;
	color: var(--color-text);
	letter-spacing: -0.02em;
	overflow-wrap: break-word;
	word-break: break-word;
}

.pf-subtitle {
	margin: 0;
	font-size: clamp(1.05rem, 1.8vw, 1.3rem);
	line-height: 1.3;
	color: var(--color-text-muted);
	font-weight: 300;
	max-width: 38ch;
}

/* ── Divider ────────────────────────────────────────── */
.pf-divider {
	height: 1px;
	background: var(--divider-subtle);
	margin: clamp(1rem, 2.5vw, 2rem) 0;
}

/* ── Filters ────────────────────────────────────────── */
.pf-filters {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
	margin-bottom: clamp(1.25rem, 3vw, 2rem);
}

.pf-chip {
	display: inline-flex;
	align-items: center;
	gap: 0.4rem;
	padding: 0.35rem 0.85rem;
	border-radius: 5px;
	border: var(--chip-border);
	background: var(--chip-bg);
	color: var(--color-text-muted);
	font-family: inherit;
	font-size: clamp(0.85rem, 1.3vw, 1rem);
	cursor: pointer;
	transition: color 200ms ease, border-color 200ms ease, background-color 200ms ease;
	text-transform: inherit;
	letter-spacing: inherit;
}

.pf-chip:hover {
	color: var(--color-text);
	border-color: rgba(255, 215, 0, 0.45);
}

.pf-chip.is-active {
	color: var(--color-accent);
	border-color: var(--color-accent);
	background: rgba(255, 215, 0, 0.10);
}

.pf-chip__dot {
	width: 6px;
	height: 6px;
	border-radius: 50%;
	background: var(--color-accent);
	box-shadow: 0 0 8px var(--accent-glow-soft);
	display: none;
}

.pf-chip.is-active .pf-chip__dot {
	display: block;
}

/* ── Stage / carousel ──────────────────────────────── */
.pf-stage {
	position: relative;
	display: grid;
	grid-template-columns: auto 1fr auto;
	align-items: center;
	gap: clamp(0.75rem, 2vw, 1.5rem);
	margin-top: clamp(1rem, 3vw, 2rem);
}

.pf-deck {
	position: relative;
	width: 100%;
	height: clamp(380px, 50vh, 520px);
	perspective: 1400px;
	transform-style: preserve-3d;
}

.pf-nav {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 44px;
	height: 44px;
	padding: 0;
	border-radius: 999px;
	border: 1px solid var(--divider-subtle);
	background: transparent;
	color: var(--color-text-muted);
	cursor: pointer;
	transition: color 200ms ease, border-color 200ms ease;
}

.pf-nav:hover,
.pf-nav:focus-visible {
	outline: none;
	color: var(--color-accent);
	border-color: color-mix(in srgb, var(--color-accent) 45%, transparent);
}

/* ── Card 3d ──────────────────────────────────────── */
.pf-card3d {
	position: absolute;
	top: 50%;
	left: 50%;
	width: min(100%, 360px);
	height: 100%;
	display: flex;
	flex-direction: column;
	gap: 1rem;
	padding: clamp(1.1rem, 2.4vw, 1.6rem);
	border-radius: 14px;
	background: var(--card-bg);
	border: var(--card-border);
	box-shadow: var(--card-shadow);
	transform-origin: center center;
	transform-style: preserve-3d;
	will-change: transform, opacity;
	transition:
		transform 540ms cubic-bezier(0.22, 1, 0.36, 1),
		opacity 420ms ease,
		filter 420ms ease;
}

.pf-card3d[data-pos="0"] {
	transform: translate(-50%, -50%) translateZ(0) rotateY(0deg) scale(1);
	opacity: 1;
	z-index: 5;
	filter: none;
	cursor: default;
}

.pf-card3d[data-pos="-1"] {
	transform: translate(-50%, -50%) translateX(-110%) rotateY(35deg) scale(0.82);
	opacity: 0.55;
	z-index: 3;
	filter: blur(0.3px) saturate(0.85);
	cursor: pointer;
}

.pf-card3d[data-pos="1"] {
	transform: translate(-50%, -50%) translateX(110%) rotateY(-35deg) scale(0.82);
	opacity: 0.55;
	z-index: 3;
	filter: blur(0.3px) saturate(0.85);
	cursor: pointer;
}

.pf-card3d[data-pos="hidden"] {
	transform: translate(-50%, -50%) translateZ(-260px) scale(0.7);
	opacity: 0;
	z-index: 1;
	pointer-events: none;
}

/* ── Card 3d content ──────────────────────────────── */
.pf-card3d__top {
	display: grid;
	grid-template-columns: 56px 1fr auto;
	align-items: center;
	gap: 0.85rem;
}

.pf-card3d__num {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 56px;
	height: 56px;
	border-radius: 6px;
	border: 1px solid var(--divider-subtle);
	background: var(--avatar-bg);
	color: var(--color-text-muted);
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 1.1rem;
}

.pf-card3d.is-template .pf-card3d__num {
	background: transparent;
	border-style: dashed;
	border-color: color-mix(in srgb, var(--color-text-muted) 55%, transparent);
	font-size: 1.7rem;
	font-weight: 300;
	opacity: 0.7;
}

.pf-card3d__id {
	display: flex;
	flex-direction: column;
	gap: 0.15rem;
	min-width: 0;
}

.pf-card3d__title {
	margin: 0;
	font-size: 1.25rem;
	font-weight: 600;
	color: var(--color-text);
	line-height: 1;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.pf-card3d.is-template .pf-card3d__title {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-weight: 500;
	font-size: 1.05rem;
	color: var(--color-text-muted);
	text-transform: none;
	opacity: 0.9;
}

.pf-card3d__cat {
	margin: 0;
	font-size: 0.92rem;
	color: var(--color-accent);
	line-height: 1;
	opacity: 0.85;
}

.pf-card3d.is-template .pf-card3d__cat {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.85rem;
	color: var(--color-text-muted);
	opacity: 0.6;
}

.pf-card3d__year {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.85rem;
	color: var(--color-text-muted);
	letter-spacing: 0.08em;
}

.pf-card3d__body {
	margin: 0;
	padding: 0.2rem 0;
	flex: 1;
	font-size: clamp(1rem, 2vw, 1.15rem);
	line-height: 1.35;
	color: var(--color-text);
}

.pf-card3d__body p {
	margin: 0;
}

.pf-card3d.is-filled .pf-card3d__body p::before {
	font-family: Georgia, "Times New Roman", serif;
	color: var(--color-accent);
	opacity: 0.7;
	content: "«";
	margin-right: 0.15em;
}

.pf-card3d.is-filled .pf-card3d__body p::after {
	font-family: Georgia, "Times New Roman", serif;
	color: var(--color-accent);
	opacity: 0.7;
	content: "»";
	margin-left: 0.15em;
}

.pf-card3d.is-template .pf-card3d__body {
	display: flex;
	flex-direction: column;
	gap: 0.4rem;
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.95rem;
	line-height: 1.4;
	color: var(--color-text-muted);
	opacity: 0.78;
}

.pf-card3d__body--empty {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.92rem;
	color: var(--color-text-muted);
	opacity: 0.55;
}

.pf-sym {
	color: var(--color-accent);
	opacity: 0.7;
}

.pf-caret {
	display: inline-block;
	color: var(--color-accent);
	margin-left: 0.1rem;
	animation: pf-caret-blink 1.05s steps(1, end) infinite;
}

@keyframes pf-caret-blink {
	0%, 49% { opacity: 1; }
	50%, 100% { opacity: 0; }
}

.pf-card3d__foot {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	padding-top: 0.75rem;
	border-top: 1px dashed var(--divider-subtle);
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.78rem;
	letter-spacing: 0.08em;
	color: var(--color-text-muted);
}

.pf-card3d__tags {
	color: var(--color-accent);
	opacity: 0.85;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.pf-card3d__dot {
	opacity: 0.5;
	flex-shrink: 0;
}

.pf-card3d__cta {
	margin-left: auto;
	color: var(--color-text-muted);
	transition: color 180ms ease;
}

.pf-card3d__cta:hover {
	color: var(--color-accent);
}

/* ── Bottom bar ─────────────────────────────────────── */
.pf-bottom {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 1rem;
	margin-top: clamp(1.25rem, 3vw, 2rem);
	padding-top: clamp(0.75rem, 1.5vw, 1rem);
	border-top: 1px solid var(--divider-subtle);
	flex-wrap: wrap;
}

.pf-bottom__cta {
	display: inline-flex;
	align-items: center;
	gap: 0.45rem;
	font-size: clamp(1.3rem, 2.6vw, 1.9rem);
	font-weight: 300;
	color: var(--color-text);
	transition: color 180ms ease;
}

.pf-bottom__cta:hover {
	color: var(--color-accent);
}

.pf-bottom__cta svg {
	transition: transform 240ms ease;
}

.pf-bottom__cta:hover svg {
	transform: translate(2px, -2px);
}

.pf-counter {
	margin: 0;
	font-family: 'JetBrains Mono', ui-monospace, monospace;
	font-size: 0.85rem;
	letter-spacing: 0.08em;
	color: var(--color-text-muted);
}

.pf-counter__sep {
	margin: 0 0.25rem;
	opacity: 0.4;
}

/* ── Hidden by filter ───────────────────────────────── */
.pf-card3d--hidden {
	display: none;
}

/* ── Tablet ─────────────────────────────────────────── */

/* ── Mobile ─────────────────────────────────────────── */
@media (max-width: 767px) {
	.pf-title {
		font-size: clamp(1.8rem, 7.2vw, 2.7rem);
	}

	.pf-subtitle br {
		display: none;
	}

	.pf-filters {
		flex-wrap: wrap;
	}

	.pf-chip {
		padding: 0.4rem 0.9rem;
	}

	.pf-stage {
		gap: 0.5rem;
	}

	.pf-deck {
		height: clamp(420px, 60vh, 500px);
	}

	.pf-nav {
		width: 36px;
		height: 36px;
	}

	.pf-card3d {
		width: min(100%, 320px);
		padding: clamp(0.95rem, 3vw, 1.3rem);
	}

	.pf-card3d[data-pos="-1"] {
		transform: translate(-50%, -50%) translateX(-92%) rotateY(28deg) scale(0.82);
	}

	.pf-card3d[data-pos="1"] {
		transform: translate(-50%, -50%) translateX(92%) rotateY(-28deg) scale(0.82);
	}

	.pf-bottom {
		flex-direction: column;
		align-items: stretch;
		gap: clamp(0.75rem, 2vw, 1rem);
	}

	.pf-bottom__cta {
		font-size: clamp(1.2rem, 5vw, 1.6rem);
		justify-content: center;
		padding: 0.6rem 0;
		border: 1px solid var(--divider-subtle);
		border-radius: var(--radius-card);
		white-space: nowrap;
	}

	.pf-counter {
		text-align: center;
	}
}

/* ── Small mobile ───────────────────────────────────── */
@media (max-width: 400px) {
	.pf-title {
		font-size: clamp(1.6rem, 6.6vw, 2.1rem);
	}

	.pf-card3d__top {
		grid-template-columns: 48px 1fr auto;
		gap: 0.65rem;
	}

	.pf-card3d__num {
		width: 48px;
		height: 48px;
	}
}

/* ── Reduced motion ─────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
	.pf-card3d {
		transition: opacity 200ms ease;
		filter: none !important;
	}

	.pf-caret {
		animation: none;
	}
}
</style>

<script>
import { getGsap, ScrollTrigger } from '../../scripts/gsap';

const gsap = getGsap();
const section = document.querySelector<HTMLElement>('#portfolio');

if (section) {
	// ── Reveal animation ──────────────────────────────────
	const reveals = gsap.utils.toArray<HTMLElement>('.pf-reveal', section);
	const cards = gsap.utils.toArray<HTMLElement>('[data-pf-card]', section);

	gsap.set(reveals, { opacity: 0, y: 28 });
	gsap.set(cards, { opacity: 0, y: 36 });

	ScrollTrigger.create({
		trigger: section,
		start: 'top 80%',
		once: true,
		onEnter: () => {
			gsap.to(reveals, {
				opacity: 1,
				y: 0,
				duration: 0.7,
				stagger: 0.09,
				ease: 'power3.out',
			});

			gsap.to(cards, {
				opacity: 1,
				y: 0,
				duration: 0.8,
				stagger: 0.14,
				delay: 0.3,
				ease: 'power3.out',
			});
		},
	});

	// ── Carousel (cover-flow) ─────────────────────────────
	const stage = section.querySelector<HTMLElement>('[data-pf-stage]');
	const deck = section.querySelector<HTMLElement>('[data-pf-deck]');
	const prevBtn = section.querySelector<HTMLButtonElement>('[data-pf-prev]');
	const nextBtn = section.querySelector<HTMLButtonElement>('[data-pf-next]');
	const curEl = section.querySelector<HTMLElement>('[data-pf-cur]');
	const totalEl = section.querySelector<HTMLElement>('[data-pf-total]');
	const chips = section.querySelectorAll<HTMLButtonElement>('.pf-chip');

	let visible: HTMLElement[] = cards.slice();
	let activeIndex = 0;

	const applyPositions = () => {
		const total = visible.length;
		if (total === 0) return;

		// hide all cards first
		cards.forEach((card) => {
			card.dataset.pos = 'hidden';
			card.setAttribute('aria-hidden', 'true');
			card.setAttribute('tabindex', '-1');
		});

		// place visible cards
		visible.forEach((card, i) => {
			const offset = (i - activeIndex + total) % total;
			let pos: '0' | '1' | '-1' | 'hidden';
			if (offset === 0) pos = '0';
			else if (offset === 1 || (total === 2 && offset === 0)) pos = '1';
			else if (offset === total - 1) pos = '-1';
			else pos = 'hidden';
			card.dataset.pos = pos;
			const isFront = pos === '0';
			card.setAttribute('aria-hidden', isFront ? 'false' : 'true');
			card.setAttribute('tabindex', isFront ? '0' : '-1');
		});

		if (curEl) curEl.textContent = String(activeIndex + 1).padStart(2, '0');
		if (totalEl) totalEl.textContent = String(total).padStart(2, '0');
	};

	const go = (next: number) => {
		const total = visible.length;
		if (total === 0) return;
		activeIndex = (next + total) % total;
		applyPositions();
	};

	prevBtn?.addEventListener('click', () => go(activeIndex - 1));
	nextBtn?.addEventListener('click', () => go(activeIndex + 1));

	// Click on side card → move to center
	cards.forEach((card) => {
		card.addEventListener('click', (e) => {
			const pos = card.dataset.pos;
			if (pos === '1') {
				e.preventDefault();
				go(activeIndex + 1);
			} else if (pos === '-1') {
				e.preventDefault();
				go(activeIndex - 1);
			}
		});
	});

	// Keyboard arrows when stage is in view
	window.addEventListener('keydown', (event) => {
		if (!deck) return;
		const rect = deck.getBoundingClientRect();
		const inView = rect.bottom > 0 && rect.top < window.innerHeight;
		if (!inView) return;
		if (event.key === 'ArrowLeft') {
			event.preventDefault();
			go(activeIndex - 1);
		} else if (event.key === 'ArrowRight') {
			event.preventDefault();
			go(activeIndex + 1);
		}
	});

	// Touch swipe
	if (stage) {
		let touchStartX = 0;
		let touchStartY = 0;
		const threshold = 48;
		stage.addEventListener('touchstart', (event) => {
			const t = event.touches[0];
			if (!t) return;
			touchStartX = t.clientX;
			touchStartY = t.clientY;
		}, { passive: true });
		stage.addEventListener('touchend', (event) => {
			const t = event.changedTouches[0];
			if (!t) return;
			const dx = t.clientX - touchStartX;
			const dy = t.clientY - touchStartY;
			if (Math.abs(dx) > threshold && Math.abs(dx) > Math.abs(dy)) {
				if (dx < 0) go(activeIndex + 1);
				else go(activeIndex - 1);
			}
		}, { passive: true });
	}

	// ── Filter chips ──────────────────────────────────────
	chips.forEach((chip) => {
		chip.addEventListener('click', () => {
			chips.forEach((c) => c.classList.remove('is-active'));
			chip.classList.add('is-active');

			const filter = chip.dataset.filter;
			cards.forEach((card) => {
				const cat = card.dataset.category;
				const matches = filter === 'all' || cat === filter;
				card.classList.toggle('pf-card3d--hidden', !matches);
			});

			visible = cards.filter((c) => !c.classList.contains('pf-card3d--hidden'));
			activeIndex = 0;
			applyPositions();
		});
	});

	applyPositions();

	// ── CTA fill effect ───────────────────────────────────
	section.querySelectorAll<HTMLElement>('[data-hover-fill]').forEach((link) => {
		link.addEventListener('pointerenter', (e) => {
			const rect = link.getBoundingClientRect();
			const lx = Math.max(0, Math.min(rect.width, e.clientX - rect.left));
			const ly = Math.max(0, Math.min(rect.height, e.clientY - rect.top));
			const maxR = Math.max(
				...[
					[0, 0],
					[rect.width, 0],
					[0, rect.height],
					[rect.width, rect.height],
				].map(([cx, cy]) => Math.hypot((cx as number) - lx, (cy as number) - ly)),
			);
			link.style.setProperty('--hero-fill-x', `${(lx / rect.width) * 100}%`);
			link.style.setProperty('--hero-fill-y', `${(ly / rect.height) * 100}%`);
			link.style.setProperty('--hero-fill-target', `${Math.ceil(maxR + 8)}px`);
			link.classList.add('is-hovered');
		});
		link.addEventListener('pointerleave', () => link.classList.remove('is-hovered'));
	});
}
</script>
