---
import { DEFAULT_SITE_CONTENT, type PortfolioItem } from '../../data/site-content';

interface Props {
	portfolio?: PortfolioItem[];
}

const { portfolio = DEFAULT_SITE_CONTENT.portfolio } = Astro.props;
const items = (portfolio.length ? portfolio : DEFAULT_SITE_CONTENT.portfolio).filter((p) => p.published);

const isPlaceholder = (item: PortfolioItem) => /ваш(?:е)?\s+будущ/i.test(item.title);
const isTemplateCard = (item: PortfolioItem) =>
	isPlaceholder(item) || /^название\s/i.test(item.title);

const categories = ['все проекты', ...new Set(items.map((p) => p.category))];


---

<section id="portfolio" class="section-anchor pf-section">
	<div class="pf-shell site-shell">

		<!-- ── Header ──────────────────────────────────────── -->
		<div class="pf-head">
			<div class="pf-head__mark">
				<span class="section-mark pf-reveal">мои работы</span>
			</div>
			<h2 class="pf-title pf-reveal">отобранные проекты, <span class="pf-title__sub">в которых идея,<br />технологии и визуал работают как единое целое.</span></h2>
		</div>

		<!-- ── Divider ─────────────────────────────────────── -->
		<div class="pf-divider pf-reveal" aria-hidden="true"></div>

		<!-- ── Filters ─────────────────────────────────────── -->
		<nav class="pf-filters pf-reveal" aria-label="фильтр проектов">
			{categories.map((cat, i) => (
				<button
					type="button"
					class:list={['pf-chip', { 'is-active': i === 0 }]}
					data-filter={i === 0 ? 'all' : cat}
				>
					<span class="pf-chip__dot" aria-hidden="true"></span>
					{cat}
				</button>
			))}
		</nav>

		<!-- ── Project carousel deck ───────────────────────── -->
		<div class="pf-stage" data-pf-stage>
			<button
				type="button"
				class="pf-nav pf-nav--prev"
				data-pf-prev
				aria-label="предыдущий проект"
			>
				<span aria-hidden="true">‹</span>
			</button>

			<div class="pf-deck" data-pf-deck>
				{items.map((item, idx) => {
					const num = String(idx + 1).padStart(2, '0');
					const isTpl = isTemplateCard(item);

					return (
						<article
							class:list={['pf-card3d', isTpl ? 'is-template' : 'is-filled']}
							data-pf-card
							data-category={item.category}
							data-index={idx}
							aria-hidden={idx === 0 ? 'false' : 'true'}
							tabindex={idx === 0 ? 0 : -1}
							data-live-url={isTpl ? undefined : item.liveUrl}
							data-duration={isTpl ? undefined : item.duration}
							data-client={isTpl ? undefined : item.client}
							data-all-tags={isTpl ? undefined : JSON.stringify(item.tags)}
							data-description={isTpl ? undefined : item.description}
							data-preview-url={isTpl ? undefined : (item.preview?.variants[0]?.url || item.preview?.originalUrl || '')}
						>
							{!isTpl && item.logo && (
								<img
									src={item.logo}
									alt=""
									aria-hidden="true"
									class="pf-card3d__watermark"
								/>
							)}
							<div class="pf-card3d__top">
								<div class="pf-card3d__num" aria-hidden="true">
									<span>{isTpl ? '?' : num}</span>
								</div>
								<div class="pf-card3d__id">
									{isTpl ? (
										<>
											<p class="pf-card3d__title">
												<span class="pf-sym">{`{`}</span> name <span class="pf-sym">{`}`}</span>
											</p>
											<p class="pf-card3d__cat">
												<span class="pf-sym">{`<`}</span>category<span class="pf-sym">{` />`}</span>
											</p>
										</>
									) : (
										<>
											<p class="pf-card3d__title">{item.title}</p>
											<p class="pf-card3d__cat">{item.category}</p>
										</>
									)}
								</div>
								<div class="pf-card3d__year">{isTpl ? '____' : item.year}</div>
							</div>

							<blockquote class="pf-card3d__body">
								{isTpl ? (
									<>
										<p><span class="pf-sym">//</span> project.description</p>
										<p><span class="pf-sym">//</span> ─ ─ ─ <span class="pf-caret" aria-hidden="true">_</span></p>
									</>
								) : (
									<>
										{item.description && <p>{item.description}</p>}
										<p class="pf-card3d__stack">{item.tags.slice(0, 3).join(' · ')}</p>
									</>
								)}
							</blockquote>

							<footer class="pf-card3d__foot">
								{isTpl ? (
									<>
										<span class="pf-card3d__tags">
											<span class="pf-sym">[</span> tags <span class="pf-sym">]</span>
										</span>
										<span class="pf-card3d__dot" aria-hidden="true">•</span>
										<a href="#contact" class="pf-card3d__cta">обсудить</a>
									</>
								) : (
									<a href={item.caseUrl} class="pf-card3d__cta">смотреть →</a>
								)}
							</footer>
						</article>
					);
				})}
			</div>

			<button
				type="button"
				class="pf-nav pf-nav--next"
				data-pf-next
				aria-label="следующий проект"
			>
				<span aria-hidden="true">›</span>
			</button>
		</div>

		<!-- ── Bottom bar ──────────────────────────────────── -->
		<div class="pf-bottom pf-reveal">
			<p class="pf-counter" data-pf-counter>
				<span data-pf-cur>01</span>
				<span class="pf-counter__sep">/</span>
				<span data-pf-total>01</span>
			</p>
			<a href="#contact" class="pf-bottom__cta" data-hover-fill data-label="обсудить проект">
				обсудить проект
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
					<path d="M1 13L13 1M13 1H5M13 1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
				</svg>
			</a>
		</div>

	</div>

	<div class="pf-detail-overlay" data-pf-overlay hidden aria-hidden="true">
		<div class="pf-detail-backdrop" data-pf-backdrop></div>
		<article class="pf-detail" data-pf-detail role="dialog" aria-modal="true" aria-label="детали проекта">
			<button type="button" class="pf-detail__close" data-pf-detail-close aria-label="закрыть">
				<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
					<path d="M6 6L22 22M22 6L6 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
				</svg>
			</button>

			<div class="pf-detail__layout">
				<div class="pf-detail__preview" data-pf-detail-preview>
					<img class="pf-detail__img" data-pf-detail-img src="" alt="" decoding="async" />
					<img class="pf-detail__logo" data-pf-detail-logo src="" alt="" aria-hidden="true" decoding="async" />
				</div>

				<div class="pf-detail__info">
					<div class="pf-detail__head">
						<div class="pf-detail__num-box">
							<span data-pf-detail-num></span>
						</div>
						<div class="pf-detail__id">
							<p class="pf-detail__title" data-pf-detail-title></p>
							<p class="pf-detail__cat" data-pf-detail-cat></p>
						</div>
						<div class="pf-detail__year" data-pf-detail-year></div>
					</div>

					<blockquote class="pf-detail__desc" data-pf-detail-desc></blockquote>

					<div class="pf-detail__tags" data-pf-detail-tags></div>

					<div class="pf-detail__foot" data-pf-detail-foot>
						<span data-pf-detail-duration></span>
						<span class="pf-detail__dot">•</span>
						<span data-pf-detail-client></span>
					</div>

					<a class="pf-detail__cta" data-pf-detail-link href="#" target="_blank" rel="noopener">
						перейти на сайт
						<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
							<path d="M1 13L13 1M13 1H5M13 1V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
						</svg>
					</a>
				</div>
			</div>
		</article>
	</div>
</section>

<style>
/* ══════════════════════════════════════════════════════
   Portfolio Editorial Grid
   ══════════════════════════════════════════════════════ */

.pf-section {
	padding: clamp(2rem, 5vw, 4rem) 0;
	overflow: hidden;
}

/* ── Header ─────────────────────────────────────────── */
.pf-head {
	display: flex;
	flex-direction: column;
	gap: clamp(0.4rem, 1vw, 0.75rem);
}

.pf-head__mark {
	display: flex;
	align-items: center;
	gap: 0.75rem;
}

.pf-title {
	margin: 0;
	font-size: clamp(2.4rem, 5.4vw, 4.5rem);
	font-weight: 300;
	line-height: 0.95;
	color: var(--color-text);
	letter-spacing: -0.02em;
	overflow-wrap: break-word;
	word-break: break-word;
}

.pf-title__sub {
	font-size: 0.5em;
	color: var(--color-text-muted);
	line-height: 1.3;
}

/* ── Divider ────────────────────────────────────────── */
.pf-divider {
	height: 1px;
	background: var(--divider-subtle);
	margin: clamp(1rem, 2.5vw, 2rem) 0;
}

/* ── Filters ────────────────────────────────────────── */
.pf-filters {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
	margin-bottom: clamp(1.25rem, 3vw, 2rem);
}

.pf-chip {
	display: inline-flex;
	align-items: center;
	gap: 0.4rem;
	padding: 0.35rem 0.85rem;
	border-radius: 5px;
	border: var(--chip-border);
	background: var(--chip-bg);
	color: var(--color-text-muted);
	font-family: inherit;
	font-size: clamp(0.85rem, 1.3vw, 1rem);
	cursor: pointer;
	transition: color 200ms ease, border-color 200ms ease, background-color 200ms ease;
	text-transform: inherit;
	letter-spacing: inherit;
}

.pf-chip:hover {
	color: var(--color-text);
	border-color: rgba(255, 215, 0, 0.45);
}

.pf-chip.is-active {
	color: var(--color-accent);
	border-color: var(--color-accent);
	background: rgba(255, 215, 0, 0.10);
}

.pf-chip__dot {
	width: 6px;
	height: 6px;
	border-radius: 50%;
	background: var(--color-accent);
	box-shadow: 0 0 8px var(--accent-glow-soft);
	display: none;
}

.pf-chip.is-active .pf-chip__dot {
	display: block;
}

/* ── Stage / carousel ──────────────────────────────── */
.pf-stage {
	position: relative;
	display: grid;
	grid-template-columns: auto 1fr auto;
	align-items: center;
	gap: clamp(0.75rem, 2vw, 1.5rem);
	margin-top: clamp(1rem, 3vw, 2rem);
}

.pf-deck {
	position: relative;
	width: min(100%, 420px);
	aspect-ratio: 320 / 440;
	margin-inline: auto;
	perspective: 1400px;
	transform-style: preserve-3d;
}

.pf-nav {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	width: 44px;
	height: 44px;
	padding: 0;
	border: none;
	background: transparent;
	color: var(--color-text);
	font-size: 2rem;
	line-height: 1;
	cursor: pointer;
	transition: color 180ms ease, text-shadow 180ms ease, transform 180ms ease;
}

.pf-nav:hover,
.pf-nav:focus-visible {
	outline: none;
	color: var(--color-accent);
	text-shadow: 0 0 14px color-mix(in srgb, var(--color-accent) 55%, transparent);
}

.pf-nav:active {
	transform: scale(0.9);
}

/* ── Card 3d ──────────────────────────────────────── */
.pf-card3d {
	position: absolute;
	inset: 0;
	display: flex;
	flex-direction: column;
	gap: 1rem;
	padding: clamp(1.1rem, 2.4vw, 1.6rem);
	border-radius: 14px;
	overflow: visible;
	background: var(--card-bg);
	border: 1px solid var(--divider-subtle);
	box-shadow: var(--card-shadow);
	transform-origin: 50% 50%;
	transform-style: preserve-3d;
	will-change: transform, opacity;
	transition:
		transform 540ms cubic-bezier(0.22, 1, 0.36, 1),
		opacity 420ms ease,
		filter 420ms ease;
}

.pf-card3d[data-pos="0"] {
	transform: translate3d(0, 0, 0) rotateY(0deg) scale(1);
	opacity: 1;
	z-index: 5;
	filter: none;
	cursor: default;
	border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
}

.pf-card3d[data-pos="1"] {
	transform: translateX(58%) rotateY(-45deg) scale(0.84);
	opacity: 0.75;
	z-index: 3;
	filter: blur(0.4px) saturate(0.88);
	cursor: pointer;
}

.pf-card3d[data-pos="-1"] {
	transform: translateX(-140%) rotateY(45deg) scale(0.78);
	opacity: 0;
	z-index: 1;
	pointer-events: none;
}

.pf-card3d[data-pos="hidden"] {
	transform: translateX(58%) translateZ(-300px) rotateY(-45deg) scale(0.7);
	opacity: 0;
	z-index: 0;
	pointer-events: none;
}

/* ── Watermark logo ───────────────────────────────── */
.pf-card3d__watermark {
	position: absolute;
	bottom: 0;
	left: -25%;
	width: 75%;
	height: auto;
	transform: translateY(50%);
	opacity: 1;
	filter: grayscale(1) brightness(1.8);
	pointer-events: none;
	user-select: none;
}

:global([data-theme="light"]) .pf-card3d__watermark {
	filter: grayscale(1) brightness(0.7);
}

/* ── Card 3d content ──────────────────────────────── */
.pf-card3d__top {
	display: grid;
	grid-template-columns: 56px 1fr auto;
	align-items: center;
	gap: 0.85rem;
}

.pf-card3d__num {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 56px;
	height: 56px;
	border-radius: 6px;
	border: 1px solid var(--divider-subtle);
	background: var(--avatar-bg);
	color: var(--color-text-muted);
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 1.1rem;
}

.pf-card3d.is-template .pf-card3d__num {
	background: transparent;
	border-style: dashed;
	border-color: color-mix(in srgb, var(--color-text-muted) 55%, transparent);
	font-size: 1.7rem;
	font-weight: 300;
	opacity: 0.7;
}

.pf-card3d__id {
	display: flex;
	flex-direction: column;
	gap: 0.15rem;
	min-width: 0;
}

.pf-card3d__title {
	margin: 0;
	font-size: 1.85rem;
	font-weight: 300;
	color: var(--color-text);
	line-height: 1;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.pf-card3d.is-template .pf-card3d__title {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-weight: 500;
	font-size: 1.05rem;
	color: var(--color-text-muted);
	text-transform: none;
	opacity: 0.9;
}

.pf-card3d__cat {
	margin: 0;
	font-size: 0.92rem;
	color: var(--color-accent);
	line-height: 1;
	opacity: 0.85;
}

.pf-card3d.is-template .pf-card3d__cat {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.85rem;
	color: var(--color-text-muted);
	opacity: 0.6;
}

.pf-card3d__year {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.85rem;
	color: var(--color-text-muted);
	letter-spacing: 0.08em;
}

.pf-card3d__body {
	margin: 0;
	padding: 0.2rem 0;
	flex: 1;
	font-size: clamp(1rem, 2vw, 1.15rem);
	line-height: 1.35;
	color: var(--color-text);
}

.pf-card3d__body p {
	margin: 0;
}

.pf-card3d.is-filled .pf-card3d__body p:not(.pf-card3d__stack)::before {
	font-family: Georgia, "Times New Roman", serif;
	color: var(--color-accent);
	opacity: 0.7;
	content: "«";
	margin-right: 0.15em;
}

.pf-card3d.is-filled .pf-card3d__body p:not(.pf-card3d__stack)::after {
	font-family: Georgia, "Times New Roman", serif;
	color: var(--color-accent);
	opacity: 0.7;
	content: "»";
	margin-left: 0.15em;
}

.pf-card3d.is-template .pf-card3d__body {
	display: flex;
	flex-direction: column;
	gap: 0.4rem;
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.95rem;
	line-height: 1.4;
	color: var(--color-text-muted);
	opacity: 0.78;
}

.pf-card3d__stack {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.82rem;
	letter-spacing: 0.06em;
	color: var(--color-accent);
	opacity: 0.75;
	margin-top: auto;
}

.pf-card3d__body--empty {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.92rem;
	color: var(--color-text-muted);
	opacity: 0.55;
}

.pf-sym {
	color: var(--color-accent);
	opacity: 0.7;
}

.pf-caret {
	display: inline-block;
	color: var(--color-accent);
	margin-left: 0.1rem;
	animation: pf-caret-blink 1.05s steps(1, end) infinite;
}

@keyframes pf-caret-blink {
	0%, 49% { opacity: 1; }
	50%, 100% { opacity: 0; }
}

.pf-card3d__foot {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	padding-top: 0.75rem;
	border-top: 1px dashed var(--divider-subtle);
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.78rem;
	letter-spacing: 0.08em;
	color: var(--color-text-muted);
}

.pf-card3d__tags {
	color: var(--color-accent);
	opacity: 0.85;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.pf-card3d__dot {
	opacity: 0.5;
	flex-shrink: 0;
}

.pf-card3d__cta {
	margin-left: auto;
	color: var(--color-text-muted);
	transition: color 180ms ease;
}

.pf-card3d__cta:hover {
	color: var(--color-accent);
}

/* ── Bottom bar ─────────────────────────────────────── */
.pf-bottom {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 1rem;
	margin-top: clamp(1.25rem, 3vw, 2rem);
	padding-top: clamp(0.75rem, 1.5vw, 1rem);
	border-top: 1px solid var(--divider-subtle);
	flex-wrap: wrap;
}

.pf-bottom__cta {
	display: inline-flex;
	align-items: center;
	gap: 0.45rem;
	font-size: clamp(2.2rem, 4.4vw, 2.8rem);
	font-weight: 300;
	color: var(--color-text);
	transition: color 180ms ease;
}

.pf-bottom__cta:hover {
	color: var(--color-accent);
}

.pf-bottom__cta svg {
	transition: transform 240ms ease;
}

.pf-bottom__cta:hover svg {
	transform: translate(2px, -2px);
}

.pf-counter {
	margin: 0;
	font-family: 'JetBrains Mono', ui-monospace, monospace;
	font-size: 0.85rem;
	letter-spacing: 0.08em;
	color: var(--color-text-muted);
}

.pf-counter__sep {
	margin: 0 0.25rem;
	opacity: 0.4;
}

/* ── Hidden by filter ───────────────────────────────── */
.pf-card3d--hidden {
	display: none;
}

/* ── Mobile ─────────────────────────────────────────── */
@media (max-width: 767px) {
	.pf-title {
		font-size: clamp(2.2rem, 8.5vw, 3.2rem);
	}

	.pf-chip {
		padding: 0.4rem 0.9rem;
	}

	.pf-stage {
		grid-template-columns: 1fr;
	}

	.pf-nav {
		display: none;
	}

	.pf-deck {
		width: min(100%, 320px);
	}

	.pf-card3d {
		padding: clamp(0.95rem, 3vw, 1.3rem);
	}

	.pf-card3d__watermark {
		left: -5%;
	}

	.pf-bottom {
		flex-direction: column;
		align-items: stretch;
		gap: clamp(0.75rem, 2vw, 1rem);
	}

	.pf-bottom__cta {
		display: none;
	}

	.pf-counter {
		text-align: center;
	}
}

/* ── Small mobile ───────────────────────────────────── */
@media (max-width: 400px) {
	.pf-title {
		font-size: clamp(1.6rem, 6.6vw, 2.1rem);
	}

	.pf-card3d__top {
		grid-template-columns: 48px 1fr auto;
		gap: 0.65rem;
	}

	.pf-card3d__num {
		width: 48px;
		height: 48px;
	}
}

/* ── Reduced motion ─────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
	.pf-card3d {
		transition: opacity 200ms ease;
		filter: none !important;
	}

	.pf-caret {
		animation: none;
	}
}

/* ══════════════════════════════════════════════════════
   Detail modal
   ══════════════════════════════════════════════════════ */

.pf-detail-overlay {
	position: fixed;
	inset: 0;
	z-index: 100;
}

.pf-detail-overlay[hidden] {
	display: none;
}

.pf-detail-backdrop {
	position: absolute;
	inset: 0;
	background: rgba(0, 0, 0, 0.65);
	backdrop-filter: blur(14px);
	-webkit-backdrop-filter: blur(14px);
}

:global(:root[data-theme="light"]) .pf-detail-backdrop {
	background: rgba(245, 242, 234, 0.72);
}

.pf-detail {
	position: fixed;
	overflow: hidden;
	background: var(--card-bg);
	border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
	border-radius: 14px;
	box-shadow:
		var(--card-shadow),
		0 0 80px rgba(255, 215, 0, 0.06);
	z-index: 101;
}

.pf-detail__close {
	position: absolute;
	top: 10px;
	right: 10px;
	z-index: 3;
	display: flex;
	padding: 0;
	border: none;
	background: none;
	color: var(--color-text-muted);
	cursor: pointer;
	transition: color 180ms ease;
}

.pf-detail__close:hover,
.pf-detail__close:focus-visible {
	color: var(--color-accent);
	outline: none;
}

.pf-detail__layout {
	position: relative;
	z-index: 1;
	display: flex;
	height: 100%;
}

.pf-detail__preview {
	position: relative;
	overflow: hidden;
	flex-shrink: 0;
	background: rgba(0, 0, 0, 0.25);
	display: flex;
	align-items: center;
	justify-content: center;
}

:global(:root[data-theme="light"]) .pf-detail__preview {
	background: rgba(18, 18, 18, 0.04);
}

.pf-detail__img {
	width: 100%;
	height: 100%;
	object-fit: cover;
}

.pf-detail__img[src=""] {
	display: none;
}

.pf-detail__logo {
	display: none;
}


.pf-detail__info {
	position: relative;
	flex-shrink: 0;
	display: flex;
	flex-direction: column;
	gap: clamp(1rem, 2.5vw, 1.5rem);
	padding: clamp(1.5rem, 3vw, 2.5rem);
	overflow-y: auto;
	scrollbar-width: thin;
	scrollbar-color: var(--color-accent) transparent;
}

.pf-detail__head {
	display: grid;
	grid-template-columns: 56px 1fr auto;
	align-items: center;
	gap: 0.85rem;
}

.pf-detail__num-box {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 56px;
	height: 56px;
	border-radius: 6px;
	border: 1px solid var(--divider-subtle);
	background: var(--avatar-bg);
	color: var(--color-text-muted);
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 1.1rem;
}

.pf-detail__id {
	display: flex;
	flex-direction: column;
	gap: 0.2rem;
	min-width: 0;
}

.pf-detail__title {
	margin: 0;
	font-size: 1.85rem;
	font-weight: 300;
	color: var(--color-text);
	line-height: 1;
}

.pf-detail__cat {
	margin: 0;
	font-size: 0.92rem;
	color: var(--color-accent);
	line-height: 1;
	opacity: 0.85;
}

.pf-detail__year {
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.85rem;
	color: var(--color-text-muted);
	letter-spacing: 0.08em;
}

.pf-detail__desc {
	margin: 0;
	font-size: clamp(1.05rem, 1.8vw, 1.2rem);
	line-height: 1.4;
	color: var(--color-text);
	max-width: 52ch;
}

.pf-detail__desc:not(:empty)::before {
	content: "«";
	color: var(--color-accent);
	opacity: 0.7;
	font-family: Georgia, "Times New Roman", serif;
	margin-right: 0.12em;
}

.pf-detail__desc:not(:empty)::after {
	content: "»";
	color: var(--color-accent);
	opacity: 0.7;
	font-family: Georgia, "Times New Roman", serif;
	margin-left: 0.12em;
}

.pf-detail__tags {
	display: flex;
	flex-wrap: wrap;
	gap: 0.45rem;
}

.pf-detail__tags:empty {
	display: none;
}

.pf-detail__tag {
	padding: 0.28rem 0.7rem;
	font-size: clamp(0.85rem, 1.3vw, 0.95rem);
	border: var(--chip-border);
	border-radius: 999px;
	color: var(--color-accent);
	background: var(--chip-bg);
}

.pf-detail__foot {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	padding-top: 0.75rem;
	border-top: 1px dashed var(--divider-subtle);
	font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
	font-size: 0.78rem;
	letter-spacing: 0.08em;
	color: var(--color-text-muted);
	text-transform: none;
}

.pf-detail__foot:empty,
.pf-detail__foot[hidden] {
	display: none;
}

.pf-detail__dot {
	opacity: 0.5;
}

.pf-detail__cta {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	margin-top: auto;
	padding-top: 0.5rem;
	font-size: clamp(1.1rem, 2vw, 1.3rem);
	font-weight: 300;
	color: var(--color-accent);
	transition: color 180ms ease;
}

.pf-detail__cta:hover {
	color: var(--color-text);
}

.pf-detail__cta svg {
	transition: transform 240ms ease;
}

.pf-detail__cta:hover svg {
	transform: translate(2px, -2px);
}

.pf-detail__cta[hidden] {
	display: none;
}

@media (max-width: 767px) {
	.pf-detail__layout {
		flex-direction: column;
	}

	.pf-detail__preview {
		width: 100% !important;
		min-height: 160px;
		max-height: 220px;
	}

	.pf-detail__info {
		width: 100% !important;
	}

	.pf-detail__title {
		font-size: 1.5rem;
	}

	.pf-detail__head {
		grid-template-columns: 48px 1fr auto;
		gap: 0.65rem;
	}

	.pf-detail__num-box {
		width: 48px;
		height: 48px;
	}
}
</style>

<script>
import { getGsap, ScrollTrigger } from '../../scripts/gsap';

const gsap = getGsap();
const section = document.querySelector<HTMLElement>('#portfolio');

if (section) {
	// ── Reveal animation ──────────────────────────────────
	const reveals = gsap.utils.toArray<HTMLElement>('.pf-reveal', section);
	const cards = gsap.utils.toArray<HTMLElement>('[data-pf-card]', section);

	gsap.set(reveals, { opacity: 0, y: 28 });

	ScrollTrigger.create({
		trigger: section,
		start: 'top 80%',
		once: true,
		onEnter: () => {
			gsap.to(reveals, {
				opacity: 1,
				y: 0,
				duration: 0.7,
				stagger: 0.09,
				ease: 'power3.out',
			});
		},
	});

	// ── Carousel (cover-flow) ─────────────────────────────
	const stage = section.querySelector<HTMLElement>('[data-pf-stage]');
	const deck = section.querySelector<HTMLElement>('[data-pf-deck]');
	const prevBtn = section.querySelector<HTMLButtonElement>('[data-pf-prev]');
	const nextBtn = section.querySelector<HTMLButtonElement>('[data-pf-next]');
	const curEl = section.querySelector<HTMLElement>('[data-pf-cur]');
	const totalEl = section.querySelector<HTMLElement>('[data-pf-total]');
	const chips = section.querySelectorAll<HTMLButtonElement>('.pf-chip');

	let visible: HTMLElement[] = cards.slice();
	let activeIndex = 0;

	const applyPositions = () => {
		const total = visible.length;
		if (total === 0) return;

		// hide all cards first
		cards.forEach((card) => {
			card.dataset.pos = 'hidden';
			card.setAttribute('aria-hidden', 'true');
			card.setAttribute('tabindex', '-1');
		});

		// place visible cards
		visible.forEach((card, i) => {
			const offset = (i - activeIndex + total) % total;
			let pos: '0' | '1' | '-1' | 'hidden';
			if (offset === 0) pos = '0';
			else if (offset === 1 || (total === 2 && offset === 0)) pos = '1';
			else if (offset === total - 1) pos = '-1';
			else pos = 'hidden';
			card.dataset.pos = pos;
			const isFront = pos === '0';
			card.setAttribute('aria-hidden', isFront ? 'false' : 'true');
			card.setAttribute('tabindex', isFront ? '0' : '-1');
		});

		if (curEl) curEl.textContent = String(activeIndex + 1).padStart(2, '0');
		if (totalEl) totalEl.textContent = String(total).padStart(2, '0');
	};

	const go = (next: number) => {
		const total = visible.length;
		if (total === 0) return;
		activeIndex = (next + total) % total;
		applyPositions();
	};

	prevBtn?.addEventListener('click', () => go(activeIndex - 1));
	nextBtn?.addEventListener('click', () => go(activeIndex + 1));

	// Click on right peek → it becomes center
	cards.forEach((card) => {
		card.addEventListener('click', (e) => {
			if (card.dataset.pos === '1') {
				e.preventDefault();
				go(activeIndex + 1);
			}
		});
	});

	// Keyboard arrows when stage is in view
	window.addEventListener('keydown', (event) => {
		if (!deck) return;
		const rect = deck.getBoundingClientRect();
		const inView = rect.bottom > 0 && rect.top < window.innerHeight;
		if (!inView) return;
		if (event.key === 'ArrowLeft') {
			event.preventDefault();
			go(activeIndex - 1);
		} else if (event.key === 'ArrowRight') {
			event.preventDefault();
			go(activeIndex + 1);
		}
	});

	// Touch swipe
	if (stage) {
		let touchStartX = 0;
		let touchStartY = 0;
		const threshold = 48;
		stage.addEventListener('touchstart', (event) => {
			const t = event.touches[0];
			if (!t) return;
			touchStartX = t.clientX;
			touchStartY = t.clientY;
		}, { passive: true });
		stage.addEventListener('touchend', (event) => {
			const t = event.changedTouches[0];
			if (!t) return;
			const dx = t.clientX - touchStartX;
			const dy = t.clientY - touchStartY;
			if (Math.abs(dx) > threshold && Math.abs(dx) > Math.abs(dy)) {
				if (dx < 0) go(activeIndex + 1);
				else go(activeIndex - 1);
			}
		}, { passive: true });
	}

	// ── Filter chips ──────────────────────────────────────
	chips.forEach((chip) => {
		chip.addEventListener('click', () => {
			chips.forEach((c) => c.classList.remove('is-active'));
			chip.classList.add('is-active');

			const filter = chip.dataset.filter;
			cards.forEach((card) => {
				const cat = card.dataset.category;
				const matches = filter === 'all' || cat === filter;
				card.classList.toggle('pf-card3d--hidden', !matches);
			});

			visible = cards.filter((c) => !c.classList.contains('pf-card3d--hidden'));
			activeIndex = 0;
			applyPositions();
		});
	});

	applyPositions();

	// ── CTA fill effect ───────────────────────────────────
	section.querySelectorAll<HTMLElement>('[data-hover-fill]').forEach((link) => {
		link.addEventListener('pointerenter', (e) => {
			const rect = link.getBoundingClientRect();
			const lx = Math.max(0, Math.min(rect.width, e.clientX - rect.left));
			const ly = Math.max(0, Math.min(rect.height, e.clientY - rect.top));
			const maxR = Math.max(
				...[
					[0, 0],
					[rect.width, 0],
					[0, rect.height],
					[rect.width, rect.height],
				].map(([cx, cy]) => Math.hypot((cx as number) - lx, (cy as number) - ly)),
			);
			link.style.setProperty('--hero-fill-x', `${(lx / rect.width) * 100}%`);
			link.style.setProperty('--hero-fill-y', `${(ly / rect.height) * 100}%`);
			link.style.setProperty('--hero-fill-target', `${Math.ceil(maxR + 8)}px`);
			link.classList.add('is-hovered');
		});
		link.addEventListener('pointerleave', () => link.classList.remove('is-hovered'));
	});

	// ── Detail modal (slide-up → expand-width) ──────────
	const overlay = document.querySelector<HTMLElement>('[data-pf-overlay]');
	const backdrop = document.querySelector<HTMLElement>('[data-pf-backdrop]');
	const detail = document.querySelector<HTMLElement>('[data-pf-detail]');
	const detailCloseBtn = document.querySelector<HTMLButtonElement>('[data-pf-detail-close]');
	const previewPanel = document.querySelector<HTMLElement>('[data-pf-detail-preview]');
	const infoEl = document.querySelector<HTMLElement>('.pf-detail__info');
	const closeBtnEl = document.querySelector<HTMLElement>('.pf-detail__close');

	if (overlay && backdrop && detail && previewPanel && infoEl) {
		let sourceCard: HTMLElement | null = null;
		let detailOpen = false;
		let animTl: ReturnType<typeof gsap.timeline> | null = null;
		let savedCardRect: DOMRect | null = null;

		const INFO_WIDTH = 420;
		const isMobile = () => window.innerWidth < 768;

		const populateDetail = (card: HTMLElement) => {
			const num = card.querySelector('.pf-card3d__num span')?.textContent ?? '';
			const title = card.querySelector('.pf-card3d__title')?.textContent ?? '';
			const cat = card.querySelector('.pf-card3d__cat')?.textContent ?? '';
			const year = card.querySelector('.pf-card3d__year')?.textContent ?? '';
			const desc = card.dataset.description ?? '';
			const liveUrl = card.dataset.liveUrl ?? '#';
			const duration = card.dataset.duration ?? '';
			const client = card.dataset.client ?? '';
			const previewUrl = card.dataset.previewUrl ?? '';
			const logoSrc = card.querySelector<HTMLImageElement>('.pf-card3d__watermark')?.src ?? '';
			let tags: string[] = [];
			try { tags = JSON.parse(card.dataset.allTags ?? '[]'); } catch {}

			const numEl = detail.querySelector('[data-pf-detail-num]');
			const titleEl = detail.querySelector('[data-pf-detail-title]');
			const catEl = detail.querySelector('[data-pf-detail-cat]');
			const yearEl = detail.querySelector('[data-pf-detail-year]');
			const descEl = detail.querySelector('[data-pf-detail-desc]');
			const linkEl = detail.querySelector<HTMLAnchorElement>('[data-pf-detail-link]');
			const durationEl = detail.querySelector('[data-pf-detail-duration]');
			const clientEl = detail.querySelector('[data-pf-detail-client]');
			const footEl = detail.querySelector<HTMLElement>('[data-pf-detail-foot]');
			const imgEl = detail.querySelector<HTMLImageElement>('[data-pf-detail-img]');
			const logoEl = detail.querySelector<HTMLImageElement>('[data-pf-detail-logo]');
			const tagsContainer = detail.querySelector('[data-pf-detail-tags]');

			if (numEl) numEl.textContent = num;
			if (titleEl) titleEl.textContent = title;
			if (catEl) catEl.textContent = cat;
			if (yearEl) yearEl.textContent = year;
			if (descEl) descEl.textContent = desc;
			if (linkEl) { linkEl.href = liveUrl; linkEl.hidden = !liveUrl || liveUrl === '#'; }
			if (durationEl) durationEl.textContent = duration;
			if (clientEl) clientEl.textContent = client;
			if (footEl) footEl.hidden = !duration && !client;
			if (imgEl) { imgEl.src = previewUrl; imgEl.alt = title; }
			if (logoEl) logoEl.src = logoSrc;

			if (tagsContainer) {
				tagsContainer.innerHTML = '';
				tags.forEach((tag) => {
					const span = document.createElement('span');
					span.className = 'pf-detail__tag';
					span.textContent = tag;
					tagsContainer.appendChild(span);
				});
			}
		};

		const resetDetail = () => {
			gsap.set(detail, { clearProps: 'all' });
			gsap.set(gsap.utils.toArray('.pf-detail__info > *', detail), { clearProps: 'all' });
			if (closeBtnEl) gsap.set(closeBtnEl, { clearProps: 'all' });
			previewPanel.style.width = '';
			infoEl.style.width = '';
			detail.style.willChange = '';
		};

		const openDetail = (card: HTMLElement) => {
			if (detailOpen) return;
			detailOpen = true;
			sourceCard = card;
			if (animTl) { animTl.kill(); animTl = null; }

			populateDetail(card);

			const cardRect = card.getBoundingClientRect();
			savedCardRect = cardRect;
			const vw = window.innerWidth;
			const vh = window.innerHeight;
			const mobile = isMobile();

			const cardW = cardRect.width;
			const cardH = cardRect.height;
			const expandedW = mobile ? vw - 32 : Math.min(cardW + INFO_WIDTH, vw - 64);
			const expandedH = mobile ? Math.min(vh - 64, cardH + 320) : cardH;

			const infoChildren = gsap.utils.toArray<HTMLElement>('.pf-detail__info > *', detail);

			previewPanel.style.width = cardW + 'px';
			infoEl.style.width = mobile ? '100%' : INFO_WIDTH + 'px';
			detail.style.willChange = 'top, left, width, height';

			gsap.set(detail, {
				position: 'fixed',
				top: cardRect.top,
				left: cardRect.left,
				width: cardW,
				height: cardH,
				opacity: 1,
				borderRadius: 14,
				force3D: true,
			});
			gsap.set(backdrop, { opacity: 0 });
			gsap.set(infoChildren, { opacity: 0, x: 24 });
			if (closeBtnEl) gsap.set(closeBtnEl, { opacity: 0, scale: 0.8 });

			card.style.visibility = 'hidden';
			overlay.hidden = false;
			overlay.setAttribute('aria-hidden', 'false');
			document.documentElement.classList.add('is-pf-detail-open');

			const centerTop = Math.max(16, (vh - expandedH) / 2);
			const centerLeft = Math.max(16, (vw - expandedW) / 2);

			const tl = gsap.timeline();
			animTl = tl;

			tl.to(detail, {
				top: Math.max(16, (vh - cardH) / 2),
				left: (vw - cardW) / 2,
				duration: 0.38,
				ease: 'power3.out',
				force3D: true,
			}, 0);

			tl.to(backdrop, {
				opacity: 1,
				duration: 0.3,
				ease: 'power2.out',
			}, 0);

			tl.to(detail, {
				width: expandedW,
				height: expandedH,
				top: centerTop,
				left: centerLeft,
				duration: 0.42,
				ease: 'power2.inOut',
				force3D: true,
			}, 0.32);

			tl.to(infoChildren, {
				opacity: 1,
				x: 0,
				duration: 0.35,
				stagger: 0.04,
				ease: 'power2.out',
			}, 0.58);

			if (closeBtnEl) {
				tl.to(closeBtnEl, {
					opacity: 1,
					scale: 1,
					duration: 0.22,
					ease: 'back.out(1.4)',
				}, 0.52);
			}

			tl.call(() => { detail.style.willChange = ''; });
		};

		const closeDetail = () => {
			if (!detailOpen) return;
			detailOpen = false;
			if (animTl) { animTl.kill(); animTl = null; }

			const card = sourceCard;
			const rect = savedCardRect;
			const infoChildren = gsap.utils.toArray<HTMLElement>('.pf-detail__info > *', detail);

			detail.style.willChange = 'top, left, width, height, opacity';

			const tl = gsap.timeline({
				onComplete: () => {
					overlay.hidden = true;
					overlay.setAttribute('aria-hidden', 'true');
					document.documentElement.classList.remove('is-pf-detail-open');
					resetDetail();
					gsap.set(infoChildren, { clearProps: 'all' });
					if (card) card.style.visibility = '';
					sourceCard = null;
					savedCardRect = null;
				},
			});
			animTl = tl;

			if (closeBtnEl) tl.to(closeBtnEl, { opacity: 0, scale: 0.8, duration: 0.1, ease: 'power2.in' }, 0);
			tl.to(infoChildren, { opacity: 0, x: 16, duration: 0.15, ease: 'power2.in' }, 0);

			if (card && rect) {
				const cardW = rect.width;
				const cardH = rect.height;
				const vw = window.innerWidth;
				const vh = window.innerHeight;

				tl.to(detail, {
					width: cardW,
					height: cardH,
					top: Math.max(16, (vh - cardH) / 2),
					left: (vw - cardW) / 2,
					duration: 0.36,
					ease: 'power2.inOut',
					force3D: true,
				}, 0.12);

				tl.to(detail, {
					top: rect.top,
					left: rect.left,
					opacity: 0,
					duration: 0.3,
					ease: 'power3.in',
					force3D: true,
				}, 0.42);
			} else {
				tl.to(detail, {
					opacity: 0,
					duration: 0.25,
					ease: 'power2.in',
				}, 0.12);
			}

			tl.to(backdrop, { opacity: 0, duration: 0.28, ease: 'power2.in' }, 0.2);
		};

		cards.forEach((card) => {
			if (!card.classList.contains('is-filled')) return;
			const cta = card.querySelector<HTMLAnchorElement>('.pf-card3d__cta');
			if (!cta) return;
			cta.addEventListener('click', (e) => {
				if (card.dataset.pos !== '0') return;
				e.preventDefault();
				openDetail(card);
			});
		});

		detailCloseBtn?.addEventListener('click', closeDetail);
		backdrop?.addEventListener('click', closeDetail);

		window.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && detailOpen) {
				e.preventDefault();
				closeDetail();
			}
		});
	}
}
</script>
