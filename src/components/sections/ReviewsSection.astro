---
const SKELETON_COUNT = 3;
const skeletons = Array.from({ length: SKELETON_COUNT });
---

<section id="reviews" class="section-anchor reviews-section">
	<header class="reviews-header">
		<span class="reviews-kicker section-mark">отзывы</span>
		<button
			type="button"
			class="reviews-link"
			data-hover-fill
			data-label="написать отзыв"
			data-reviews-write
		>
			написать отзыв
		</button>
	</header>

	<div class="reviews-stage" data-reviews-stage>
		<button
			type="button"
			class="reviews-nav reviews-nav--prev"
			data-reviews-prev
			aria-label="предыдущий отзыв"
		>
			<span aria-hidden="true">‹</span>
		</button>

		<div class="reviews-deck" data-reviews-deck aria-live="polite">
			{skeletons.map((_, index) => (
				<article
					class="reviews-card reviews-card--template"
					data-reviews-card
					data-depth={index}
					aria-hidden={index === 0 ? 'false' : 'true'}
					tabindex={index === 0 ? 0 : -1}
				>
					<div class="reviews-card__top">
						<div class="reviews-avatar reviews-tpl-avatar" aria-hidden="true">
							<span class="rv-view">?</span>
							<canvas class="rv-edit" width="7" height="7" data-rv-avatar></canvas>
						</div>
						<div class="reviews-id">
							<p class="reviews-name reviews-tpl-name">
								<span class="rv-view"><span class="reviews-tpl-sym">{`{`}</span> name <span class="reviews-tpl-sym">{`}`}</span></span>
								<input class="rv-edit rv-input rv-input--name" type="text" data-rv-name placeholder="" maxlength="80" />
							</p>
							<p class="reviews-role reviews-tpl-role">
								<span class="rv-view"><span class="reviews-tpl-sym">{`<`}</span>role<span class="reviews-tpl-sym">{` />`}</span></span>
								<input class="rv-edit rv-input rv-input--role" type="text" data-rv-role placeholder="" maxlength="100" />
							</p>
						</div>
						<div class="reviews-stars" data-rv-stars>
							{Array.from({ length: 5 }).map((_, i) => (
								<button type="button" class="reviews-star" data-rv-star={i + 1}>☆</button>
							))}
						</div>
					</div>

					<blockquote class="reviews-quote reviews-tpl-quote">
						<div class="rv-view">
							<p><span class="reviews-tpl-sym">//</span> review.quote</p>
							<p><span class="reviews-tpl-sym">//</span> ─ ─ ─ <span class="reviews-tpl-caret" aria-hidden="true">_</span></p>
						</div>
						<textarea class="rv-edit rv-textarea" data-rv-message placeholder="" maxlength="1200" rows={4}></textarea>
					</blockquote>

					<footer class="reviews-card__foot reviews-tpl-foot">
						<span class="reviews-project rv-view">
							<span class="reviews-tpl-sym">[</span> project <span class="reviews-tpl-sym">]</span>
						</span>
						<span class="reviews-dot rv-view" aria-hidden="true">•</span>
						<span class="reviews-date rv-view">__.____</span>
						<div class="rv-foot-edit rv-edit">
							<input class="rv-input rv-input--project" type="text" data-rv-project placeholder="" maxlength="120" />
							<span class="rv-actions">
								<button type="button" class="rv-btn rv-btn--cancel" data-rv-cancel>&gt; cancel</button>
								<button type="button" class="rv-btn rv-btn--submit" data-rv-submit>&gt; submit_review</button>
							</span>
						</div>
					</footer>
				</article>
			))}
		</div>

		<button
			type="button"
			class="reviews-nav reviews-nav--next"
			data-reviews-next
			aria-label="следующий отзыв"
		>
			<span aria-hidden="true">›</span>
		</button>
	</div>

	<footer class="reviews-footer">
		<div class="reviews-dots" role="tablist" aria-label="навигация по отзывам">
			{skeletons.map((_, index) => (
				<button
					type="button"
					class="reviews-dot-btn"
					data-reviews-dot
					data-index={index}
					role="tab"
					aria-selected={index === 0 ? 'true' : 'false'}
					aria-label={`слот ${index + 1}`}
				/>
			))}
		</div>
		<p class="reviews-counter" data-reviews-counter>
			<span data-reviews-current>01</span>
			<span class="reviews-counter__sep">/</span>
			<span>{String(SKELETON_COUNT).padStart(2, '0')}</span>
		</p>
	</footer>
</section>

<style>
	.reviews-section {
		display: flex;
		flex-direction: column;
		gap: clamp(1.5rem, 3vw, 2.25rem);
		padding-block: var(--section-padding);
	}

	.reviews-link {
		--hero-fill-size: 0px;
		--hero-fill-target: 220px;
		--hero-fill-x: 50%;
		--hero-fill-y: 50%;
		position: relative;
		display: inline-flex;
		align-items: center;
		padding: 0;
		border: 0;
		background: transparent;
		font-family: inherit;
		font-size: clamp(2.2rem, 4.4vw, 2.8rem);
		font-weight: 300;
		line-height: 1;
		letter-spacing: inherit;
		text-transform: inherit;
		color: var(--color-text);
		white-space: nowrap;
		cursor: pointer;
		transition: color 180ms ease;
	}

	.reviews-link:focus-visible {
		outline: none;
	}

	.reviews-link::after {
		content: attr(data-label);
		position: absolute;
		inset: 0;
		color: var(--color-accent);
		white-space: nowrap;
		pointer-events: none;
		mask-image: radial-gradient(
			circle var(--hero-fill-size) at var(--hero-fill-x) var(--hero-fill-y),
			#000 96%,
			transparent 100%
		);
		-webkit-mask-image: radial-gradient(
			circle var(--hero-fill-size) at var(--hero-fill-x) var(--hero-fill-y),
			#000 96%,
			transparent 100%
		);
		transition: --hero-fill-size 680ms cubic-bezier(0.22, 0.8, 0.24, 1);
	}

	.reviews-link.is-hovered::after {
		--hero-fill-size: var(--hero-fill-target);
	}

	@media (prefers-reduced-motion: reduce) {
		.reviews-link::after {
			transition: none;
		}
	}

	.reviews-header {
		display: flex;
		flex-wrap: nowrap;
		align-items: baseline;
		justify-content: space-between;
		gap: clamp(0.75rem, 2vw, 1.5rem);
	}

	@media (max-width: 640px) {
		.reviews-link {
			font-size: clamp(1.4rem, 5.5vw, 1.9rem);
		}
	}

	.reviews-stage {
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: clamp(0.75rem, 2vw, 1.5rem);
		min-height: 480px;
	}

	.reviews-deck {
		position: relative;
		width: min(100%, 420px);
		aspect-ratio: 320 / 440;
		margin-inline: auto;
		perspective: 1400px;
		transform-style: preserve-3d;
	}

	.reviews-card {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
		padding: clamp(1.1rem, 2.4vw, 1.6rem);
		border-radius: 14px;
		background: var(--card-bg);
		border: var(--card-border);
		box-shadow: var(--card-shadow);
		transform-style: preserve-3d;
		transform-origin: 50% 50%;
		transition:
			transform 540ms cubic-bezier(0.22, 1, 0.36, 1),
			opacity 420ms ease,
			filter 420ms ease;
		will-change: transform, opacity;
	}

	.reviews-card[data-depth="0"] {
		transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
		opacity: 1;
		filter: none;
		z-index: 5;
		cursor: default;
		border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
	}

	.reviews-card[data-depth="1"] {
		transform: translate3d(14px, 10px, -60px) rotate(3deg) scale(0.96);
		opacity: 0.82;
		filter: blur(0.3px) saturate(0.92);
		z-index: 4;
		cursor: pointer;
	}

	.reviews-card[data-depth="2"] {
		transform: translate3d(26px, 20px, -130px) rotate(5deg) scale(0.92);
		opacity: 0.55;
		filter: blur(0.6px) saturate(0.85);
		z-index: 3;
		cursor: pointer;
	}

	.reviews-card__top {
		display: grid;
		grid-template-columns: 56px 1fr auto;
		align-items: center;
		gap: 0.85rem;
	}

	.reviews-avatar {
		width: 56px;
		height: 56px;
		border-radius: 6px;
		overflow: hidden;
		border: 1px solid var(--divider-subtle);
		background: var(--avatar-bg);
		image-rendering: pixelated;
	}

	.reviews-avatar :global(svg) {
		width: 100%;
		height: 100%;
	}

	.reviews-avatar :global(.avatar-bg) {
		fill: var(--avatar-bg);
	}

	.reviews-avatar :global(.avatar-pixel) {
		fill: var(--avatar-pixel);
	}

	.reviews-avatar :global(.avatar-pixel--accent) {
		fill: var(--avatar-pixel-accent);
	}

	.reviews-id {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		min-width: 0;
	}

	.reviews-name {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--color-text);
		line-height: 1;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.reviews-role {
		margin: 0;
		font-size: 0.92rem;
		color: var(--color-text-muted);
		line-height: 1;
	}

	.reviews-stars {
		display: inline-flex;
		gap: 2px;
		font-size: 0.78rem;
		line-height: 1;
	}

	.reviews-star {
		padding: 0;
		border: none;
		background: transparent;
		font: inherit;
		font-size: inherit;
		line-height: 1;
		color: color-mix(in srgb, var(--color-text) 14%, transparent);
		cursor: default;
	}

	.reviews-star.is-on {
		color: var(--color-accent);
		text-shadow: 0 0 8px color-mix(in srgb, var(--color-accent) 45%, transparent);
	}

	.reviews-quote {
		margin: 0;
		padding: 0.2rem 0;
		flex: 1;
		font-size: clamp(1rem, 2vw, 1.15rem);
		line-height: 1.35;
		color: var(--color-text);
	}

	.reviews-quote p {
		margin: 0;
	}

	.reviews-quote p::before,
	.reviews-quote p::after {
		font-family: Georgia, "Times New Roman", serif;
		color: var(--color-accent);
		opacity: 0.7;
	}

	.reviews-quote p::before {
		content: "«";
		margin-right: 0.15em;
	}

	.reviews-quote p::after {
		content: "»";
		margin-left: 0.15em;
	}

	.reviews-card__foot {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding-top: 0.75rem;
		border-top: 1px dashed var(--divider-subtle);
		font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		color: var(--color-text-muted);
	}

	.reviews-project {
		color: var(--color-accent);
		opacity: 0.85;
	}

	.reviews-dot {
		opacity: 0.5;
	}

	.reviews-date {
		font-variant-numeric: tabular-nums;
	}

	/* ── Empty-state template ── */
	.reviews-card--template {
		font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
		letter-spacing: 0;
	}

	.reviews-tpl-avatar {
		display: flex;
		align-items: center;
		justify-content: center;
		background: transparent !important;
		border: 1px dashed color-mix(in srgb, var(--color-text-muted) 55%, transparent) !important;
		color: var(--color-text-muted);
		font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
		font-size: 1.7rem;
		font-weight: 300;
		opacity: 0.7;
	}

	.reviews-card--template .reviews-name {
		font-family: inherit;
		font-weight: 500;
		font-size: 1.05rem;
		color: var(--color-text-muted);
		text-transform: none;
		opacity: 0.9;
	}

	.reviews-card--template .reviews-role {
		font-family: inherit;
		font-size: 0.85rem;
		color: var(--color-text-muted);
		opacity: 0.6;
	}

	.reviews-tpl-sym {
		color: var(--color-accent);
		opacity: 0.7;
	}

	.reviews-card--template .reviews-quote {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		font-family: inherit;
		font-size: 0.95rem;
		line-height: 1.4;
		color: var(--color-text-muted);
		opacity: 0.78;
	}

	.reviews-card--template .reviews-quote p {
		margin: 0;
	}

	.reviews-card--template .reviews-quote p::before,
	.reviews-card--template .reviews-quote p::after {
		content: none;
	}

	.reviews-tpl-caret {
		display: inline-block;
		color: var(--color-accent);
		margin-left: 0.1rem;
		animation: reviews-tpl-blink 1.05s steps(1, end) infinite;
	}

	@keyframes reviews-tpl-blink {
		0%, 49% { opacity: 1; }
		50%, 100% { opacity: 0; }
	}

	.reviews-card--template .reviews-stars {
		opacity: 0.45;
	}

	.reviews-card--template .reviews-card__foot {
		font-family: inherit;
		opacity: 0.7;
	}

	.reviews-card--template .reviews-project {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.reviews-tpl-caret {
			animation: none;
		}
	}

	.reviews-nav {
		width: 44px;
		height: 44px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		border: none;
		background: transparent;
		color: var(--color-text);
		font-size: 2rem;
		line-height: 1;
		cursor: pointer;
		transition:
			color 180ms ease,
			text-shadow 180ms ease,
			transform 180ms ease;
	}

	.reviews-nav:hover,
	.reviews-nav:focus-visible {
		color: var(--color-accent);
		text-shadow: 0 0 14px color-mix(in srgb, var(--color-accent) 55%, transparent);
		outline: none;
	}

	.reviews-nav:active {
		transform: scale(0.9);
	}

	.reviews-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.reviews-dots {
		display: inline-flex;
		gap: 0.5rem;
	}

	.reviews-dot-btn {
		width: 10px;
		height: 10px;
		padding: 0;
		border: 1px solid var(--divider-strong);
		background: transparent;
		border-radius: 0;
		cursor: pointer;
		transition:
			background-color 220ms ease,
			border-color 220ms ease,
			transform 220ms ease;
	}

	.reviews-dot-btn[aria-selected="true"] {
		background: var(--color-accent);
		border-color: var(--color-accent);
		transform: scale(1.1);
	}

	.reviews-dot-btn:focus-visible {
		outline: 1px solid color-mix(in srgb, var(--color-accent) 60%, transparent);
		outline-offset: 3px;
	}

	.reviews-counter {
		margin: 0;
		font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
		font-size: 0.82rem;
		color: var(--color-text-muted);
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.08em;
	}

	.reviews-counter__sep {
		margin: 0 0.35rem;
		opacity: 0.5;
	}

	@media (max-width: 767px) {
		.reviews-stage {
			grid-template-columns: 1fr;
			min-height: 440px;
		}

		.reviews-nav {
			display: none;
		}

		.reviews-deck {
			width: min(100%, 320px);
		}

		.reviews-card[data-depth="1"] {
			transform: translate3d(10px, 8px, -60px) rotate(2.5deg) scale(0.96);
		}

		.reviews-card[data-depth="2"] {
			transform: translate3d(18px, 14px, -120px) rotate(4deg) scale(0.93);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.reviews-card {
			transition: opacity 200ms ease;
			filter: none !important;
		}
	}

	/* ── Inline review form (view/edit toggle) ── */
	.rv-edit {
		display: none;
	}

	.reviews-card.is-editing .rv-view {
		display: none;
	}

	.reviews-card.is-editing .rv-edit {
		display: block;
	}

	.reviews-card.is-editing .reviews-tpl-avatar {
		background: transparent !important;
		border-style: solid !important;
		border-color: var(--color-accent) !important;
		opacity: 1;
		overflow: hidden;
	}

	.reviews-card.is-editing .reviews-tpl-avatar canvas.rv-edit {
		display: block;
		width: 100%;
		height: 100%;
	}

	.reviews-card.is-editing .reviews-stars {
		opacity: 1;
	}

	.reviews-card.is-editing .reviews-star {
		cursor: pointer;
		transition: color 160ms ease, transform 160ms ease;
	}

	.reviews-card.is-editing .reviews-star:hover {
		transform: scale(1.25);
	}

	.rv-input {
		width: 100%;
		padding: 0;
		border: none;
		border-bottom: 1px dashed var(--divider-subtle);
		background: transparent;
		font: inherit;
		font-size: inherit;
		color: var(--color-text);
		outline: none;
		caret-color: var(--color-accent);
		transition: border-color 200ms ease;
	}

	.rv-input:focus {
		border-bottom-color: var(--color-accent);
	}

	.rv-input::placeholder,
	.rv-textarea::placeholder {
		color: var(--color-text-muted);
		opacity: 0.4;
		font-weight: 400;
	}

	.rv-input--name {
		font-weight: 500;
		font-size: 1.05rem;
	}

	.rv-input--role {
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	.rv-input--project {
		font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
		font-size: 0.78rem;
		letter-spacing: 0.06em;
		color: var(--color-accent);
		border-bottom: none;
	}

	.rv-textarea {
		width: 100%;
		flex: 1;
		resize: none;
		padding: 0.2rem 0;
		border: none;
		background: transparent;
		color: var(--color-text);
		font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
		font-size: 0.92rem;
		line-height: 1.4;
		outline: none;
		caret-color: var(--color-accent);
	}

	.reviews-card.is-editing .reviews-quote {
		display: flex;
		flex-direction: column;
	}

	.reviews-card.is-editing .rv-foot-edit {
		display: flex;
		width: 100%;
		align-items: center;
		gap: 0.5rem;
	}

	.rv-actions {
		display: inline-flex;
		gap: 0.6rem;
		margin-left: auto;
	}

	.rv-btn {
		padding: 0;
		border: none;
		background: transparent;
		font-family: "JetBrains Mono", "SF Mono", "Menlo", monospace;
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		cursor: pointer;
		transition: color 180ms ease, text-shadow 180ms ease;
	}

	.rv-btn--cancel {
		color: var(--color-text-muted);
	}

	.rv-btn--cancel:hover {
		color: var(--color-text);
	}

	.rv-btn--submit {
		color: var(--color-accent);
	}

	.rv-btn--submit:hover {
		text-shadow: 0 0 10px color-mix(in srgb, var(--color-accent) 40%, transparent);
	}

	.rv-btn--submit:disabled {
		opacity: 0.4;
		cursor: not-allowed;
	}
</style>

<script>
	const stage = document.querySelector<HTMLElement>('[data-reviews-stage]');
	if (stage) {
		const deck = stage.querySelector<HTMLElement>('[data-reviews-deck]');
		const cards = Array.from(
			stage.querySelectorAll<HTMLElement>('[data-reviews-card]'),
		);
		const prevBtn = stage.querySelector<HTMLButtonElement>('[data-reviews-prev]');
		const nextBtn = stage.querySelector<HTMLButtonElement>('[data-reviews-next]');
		const section = stage.closest<HTMLElement>('.reviews-section');
		const dots = section
			? Array.from(section.querySelectorAll<HTMLButtonElement>('[data-reviews-dot]'))
			: [];
		const counter = section?.querySelector<HTMLElement>('[data-reviews-current]');

		const total = cards.length;
		let activeIndex = 0;
		let editingCard: HTMLElement | null = null;

		const update = () => {
			cards.forEach((card, i) => {
				const depth = (i - activeIndex + total) % total;
				card.dataset.depth = String(depth);
				const isFront = depth === 0;
				card.setAttribute('aria-hidden', isFront ? 'false' : 'true');
				card.setAttribute('tabindex', isFront ? '0' : '-1');
			});
			dots.forEach((dot, i) => {
				dot.setAttribute(
					'aria-selected',
					i === activeIndex ? 'true' : 'false',
				);
			});
			if (counter) {
				counter.textContent = String(activeIndex + 1).padStart(2, '0');
			}
		};

		const go = (next: number) => {
			if (editingCard) return;
			activeIndex = (next + total) % total;
			update();
		};

		const next = () => go(activeIndex + 1);
		const prev = () => go(activeIndex - 1);

		prevBtn?.addEventListener('click', prev);
		nextBtn?.addEventListener('click', next);

		dots.forEach((dot) => {
			dot.addEventListener('click', () => {
				const i = Number(dot.dataset.index ?? '0');
				if (!Number.isNaN(i)) go(i);
			});
		});

		cards.forEach((card, i) => {
			card.addEventListener('click', () => {
				if (i !== activeIndex) go(i);
			});
		});

		const onKey = (event: KeyboardEvent) => {
			if (!deck) return;
			const rect = deck.getBoundingClientRect();
			const inView =
				rect.bottom > 0 && rect.top < window.innerHeight;
			if (!inView) return;
			if (event.key === 'ArrowLeft') {
				event.preventDefault();
				prev();
			} else if (event.key === 'ArrowRight') {
				event.preventDefault();
				next();
			}
		};
		window.addEventListener('keydown', onKey);

		let touchStartX = 0;
		let touchStartY = 0;
		const threshold = 48;
		stage.addEventListener(
			'touchstart',
			(event) => {
				const t = event.touches[0];
				if (!t) return;
				touchStartX = t.clientX;
				touchStartY = t.clientY;
			},
			{ passive: true },
		);
		stage.addEventListener(
			'touchend',
			(event) => {
				const t = event.changedTouches[0];
				if (!t) return;
				const dx = t.clientX - touchStartX;
				const dy = t.clientY - touchStartY;
				if (Math.abs(dx) > threshold && Math.abs(dx) > Math.abs(dy)) {
					if (dx < 0) next();
					else prev();
				}
			},
			{ passive: true },
		);

		update();

		// ── Inline review form ────────────────────
		const writeBtn = section?.querySelector<HTMLButtonElement>('[data-reviews-write]');

		const POOL = 'абвгдежзиклмнопрстуфхцчшщэюя01234_./\\|<>{}[]';
		const FRAMES = 18;

		const scramble = (el: HTMLElement): Promise<void> => new Promise((resolve) => {
			const original = el.textContent ?? '';
			const len = original.length;
			if (!len) return resolve();
			const settle: number[] = [];
			for (let i = 0; i < len; i++) {
				settle.push(Math.floor(Math.random() * FRAMES));
			}
			const last = Math.max(...settle);
			let frame = 0;
			const tick = () => {
				let out = '';
				for (let i = 0; i < len; i++) {
					out += frame >= settle[i] ? '' : POOL[Math.floor(Math.random() * POOL.length)];
				}
				el.textContent = out;
				frame++;
				if (frame > last + 1) {
					el.textContent = '';
					return resolve();
				}
				requestAnimationFrame(tick);
			};
			requestAnimationFrame(tick);
		});

		const descramble = (el: HTMLElement, target: string): Promise<void> => new Promise((resolve) => {
			const len = target.length;
			if (!len) { el.textContent = target; return resolve(); }
			const settle: number[] = [];
			for (let i = 0; i < len; i++) {
				const base = Math.floor((i / len) * FRAMES * 0.5);
				settle.push(base + Math.floor(Math.random() * (FRAMES * 0.6)));
			}
			const last = Math.max(...settle);
			let frame = 0;
			const tick = () => {
				let out = '';
				for (let i = 0; i < len; i++) {
					out += frame >= settle[i] ? target[i] : POOL[Math.floor(Math.random() * POOL.length)];
				}
				el.textContent = out;
				frame++;
				if (frame > last + 1) {
					el.textContent = target;
					return resolve();
				}
				requestAnimationFrame(tick);
			};
			requestAnimationFrame(tick);
		});

		const generatePixelAvatar = (canvas: HTMLCanvasElement) => {
			const ctx = canvas.getContext('2d');
			if (!ctx) return;
			const size = 7;
			ctx.clearRect(0, 0, size, size);
			const hue = Math.floor(Math.random() * 360);
			const bg = `hsl(${hue}, 20%, 12%)`;
			const fg = `hsl(${hue}, 70%, 60%)`;
			const accent = `hsl(${(hue + 40) % 360}, 80%, 55%)`;
			ctx.fillStyle = bg;
			ctx.fillRect(0, 0, size, size);
			for (let y = 0; y < size; y++) {
				for (let x = 0; x < Math.ceil(size / 2); x++) {
					if (Math.random() > 0.55) {
						ctx.fillStyle = Math.random() > 0.7 ? accent : fg;
						ctx.fillRect(x, y, 1, 1);
						ctx.fillRect(size - 1 - x, y, 1, 1);
					}
				}
			}
		};

		const getViewEls = (card: HTMLElement) =>
			Array.from(card.querySelectorAll<HTMLElement>('.rv-view'));

		const openForm = async () => {
			const card = cards[activeIndex];
			if (!card || editingCard) return;
			editingCard = card;

			const viewEls = getViewEls(card);
			const savedHTML = viewEls.map((el) => el.innerHTML);
			const savedText = viewEls.map((el) => el.textContent ?? '');
			card.dataset.origHTML = JSON.stringify(savedHTML);
			card.dataset.origText = JSON.stringify(savedText);

			await Promise.all(viewEls.map((el) => scramble(el)));

			const canvas = card.querySelector<HTMLCanvasElement>('[data-rv-avatar]');
			if (canvas) generatePixelAvatar(canvas);

			card.classList.add('is-editing');

			const nameInput = card.querySelector<HTMLInputElement>('[data-rv-name]');
			const roleInput = card.querySelector<HTMLInputElement>('[data-rv-role]');
			const msgArea = card.querySelector<HTMLTextAreaElement>('[data-rv-message]');
			const projInput = card.querySelector<HTMLInputElement>('[data-rv-project]');

			const descrambleInput = (el: HTMLInputElement | HTMLTextAreaElement | null, text: string, delay: number) => {
				if (!el) return;
				setTimeout(() => {
					const len = text.length;
					const settle: number[] = [];
					for (let i = 0; i < len; i++) {
						const base = Math.floor((i / len) * FRAMES * 0.4);
						settle.push(base + Math.floor(Math.random() * (FRAMES * 0.6)));
					}
					const last = Math.max(...settle, 0);
					let frame = 0;
					const tick = () => {
						let out = '';
						for (let i = 0; i < len; i++) {
							out += frame >= settle[i] ? text[i] : POOL[Math.floor(Math.random() * POOL.length)];
						}
						el.placeholder = out;
						frame++;
						if (frame > last + 1) {
							el.placeholder = text;
							return;
						}
						requestAnimationFrame(tick);
					};
					requestAnimationFrame(tick);
				}, delay);
			};

			descrambleInput(nameInput, 'ваше имя', 120);
			descrambleInput(roleInput, 'должность / компания', 200);
			descrambleInput(msgArea, '// напишите отзыв...', 280);
			descrambleInput(projInput, '[ проект ]', 380);

			if (nameInput) setTimeout(() => nameInput.focus(), 400);
		};

		const closeForm = async (card: HTMLElement) => {
			card.querySelectorAll<HTMLInputElement>('input[data-rv-name], input[data-rv-role], input[data-rv-project]')
				.forEach((i) => { i.value = ''; i.placeholder = ''; });
			const ta = card.querySelector<HTMLTextAreaElement>('[data-rv-message]');
			if (ta) { ta.value = ''; ta.placeholder = ''; }
			card.querySelectorAll<HTMLButtonElement>('[data-rv-star]')
				.forEach((s) => { s.classList.remove('is-on'); s.textContent = '☆'; });

			card.classList.remove('is-editing');

			const viewEls = getViewEls(card);
			const savedText: string[] = JSON.parse(card.dataset.origText || '[]');
			const savedHTML: string[] = JSON.parse(card.dataset.origHTML || '[]');

			await Promise.all(viewEls.map((el, i) => descramble(el, savedText[i] ?? '')));
			viewEls.forEach((el, i) => { el.innerHTML = savedHTML[i] ?? ''; });

			editingCard = null;
		};

		writeBtn?.addEventListener('click', openForm);

		cards.forEach((card) => {
			const cancelBtn = card.querySelector<HTMLButtonElement>('[data-rv-cancel]');
			const submitBtn = card.querySelector<HTMLButtonElement>('[data-rv-submit]');
			const starBtns = Array.from(card.querySelectorAll<HTMLButtonElement>('[data-rv-star]'));

			cancelBtn?.addEventListener('click', () => closeForm(card));

			starBtns.forEach((btn) => {
				btn.addEventListener('click', () => {
					if (!card.classList.contains('is-editing')) return;
					const val = Number(btn.dataset.rvStar);
					starBtns.forEach((s) => {
						const sv = Number(s.dataset.rvStar);
						const on = sv <= val;
						s.classList.toggle('is-on', on);
						s.textContent = on ? '★' : '☆';
					});
				});
			});

			submitBtn?.addEventListener('click', async () => {
				const name = card.querySelector<HTMLInputElement>('[data-rv-name]')?.value?.trim() ?? '';
				const role = card.querySelector<HTMLInputElement>('[data-rv-role]')?.value?.trim() ?? '';
				const message = card.querySelector<HTMLTextAreaElement>('[data-rv-message]')?.value?.trim() ?? '';
				const project = card.querySelector<HTMLInputElement>('[data-rv-project]')?.value?.trim() ?? '';
				const onStars = starBtns.filter((s) => s.classList.contains('is-on'));
				const stars = onStars.length || 5;

				if (!name || !message) {
					submitBtn.textContent = '> error: name & message required';
					setTimeout(() => { submitBtn.textContent = '> submit_review'; }, 2000);
					return;
				}

				submitBtn.disabled = true;
				submitBtn.textContent = '> sending...';

				try {
					const res = await fetch('/api/reviews.json', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ name, role, message, project, stars }),
					});
					const json = await res.json();
					if (json.ok) {
						submitBtn.textContent = '> done ✓';
						setTimeout(() => closeForm(card), 1200);
					} else {
						submitBtn.textContent = `> ${json.error || 'ошибка'}`;
					}
				} catch {
					submitBtn.textContent = '> network error';
				}

				setTimeout(() => {
					submitBtn.textContent = '> submit_review';
					submitBtn.disabled = false;
				}, 2500);
			});
		});
	}
</script>
