---
import { DEFAULT_SITE_CONTENT, type PortfolioItem, type PortfolioMedia } from '../../data/site-content';

interface Props {
	portfolio?: PortfolioItem[];
}

const { portfolio = DEFAULT_SITE_CONTENT.portfolio } = Astro.props;
const tiles = (portfolio.length ? portfolio : DEFAULT_SITE_CONTENT.portfolio).filter((item) => item.published);

const buildSrcSet = (media: PortfolioMedia | null) => {
	if (!media) return '';
	const sources = media.variants.map((variant) => `${variant.url} ${variant.width}w`);
	sources.push(`${media.originalUrl} ${media.width}w`);
	return sources.join(', ');
};

const buildTileSizes = (tile: PortfolioItem) =>
	tile.colSpan >= 2 ? '(max-width: 767px) 50vw, 50vw' : '(max-width: 767px) 50vw, 25vw';

const isPlaceholderProject = (item: PortfolioItem) => /ваш(?:е)?\s+будущ/i.test(item.title);
---

<section id="portfolio" class="mosaic-section section-anchor">
	<div class="mosaic-shell site-shell">
		<div class="mosaic-wrap">

			<div class="mosaic-header">
				<span class="mosaic-label section-mark">избранные работы</span>
			</div>

			<div class="mosaic-grid">
				{tiles.map((tile, i) => (
					(() => {
						const isPlaceholder = isPlaceholderProject(tile);
						return (
					<button
						class="mosaic-tile"
						data-index={i}
						data-placeholder={isPlaceholder ? 'true' : 'false'}
						data-hue={tile.hue}
						data-anim-dur={tile.animDur}
						data-category={tile.category}
						data-title={tile.title}
						data-client={tile.client}
						data-description={tile.description}
						data-tags={JSON.stringify(tile.tags)}
						data-year={tile.year}
						data-duration={tile.duration}
						data-live-url={tile.liveUrl}
						data-case-url={tile.caseUrl}
						data-preview-media={JSON.stringify(tile.preview)}
						data-detail-media={JSON.stringify(tile.detail)}
						data-mockup-media={JSON.stringify(tile.mockup)}
						style={`--col:${tile.colSpan};--row:${tile.rowSpan};--hue:${tile.hue}deg;--flicker-dur:${tile.animDur}s`}
						aria-label={`открыть проект: ${tile.title}`}
						>
							<div class="mosaic-tile__bg"></div>
							{!isPlaceholder && tile.preview && (
								<img
									class="mosaic-tile__preview"
									src={tile.preview.originalUrl}
									srcset={buildSrcSet(tile.preview)}
									sizes={buildTileSizes(tile)}
									width={tile.preview.width}
									height={tile.preview.height}
									alt=""
									loading="lazy"
									decoding="async"
								/>
							)}
							{isPlaceholder && (
								<div class="mosaic-tile__placeholder" aria-hidden="true">
									<span class="mosaic-tile__placeholder-badge">свободный слот</span>
								</div>
							)}
							<canvas class="mosaic-tile__canvas" aria-hidden="true"></canvas>
							<div class="mosaic-tile__info">
								<p class="mosaic-tile__category">{tile.category}</p>
								<p class="mosaic-tile__name">{tile.title}</p>
							</div>
						</button>
						);
					})()
				))}
			</div>

			<!-- Expand overlay (populated + animated by JS) -->
			<div class="mosaic-detail" aria-hidden="true">
				<button class="mosaic-detail__close" aria-label="закрыть">
					<svg width="14" height="14" viewBox="0 0 14 14" fill="none">
						<path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
					</svg>
				</button>
				<div class="mosaic-detail__bg"></div>
				<div class="mosaic-detail__overlay"></div>
				<div class="mosaic-detail__body"></div>
			</div>

		</div>
	</div>
</section>

<style>
/* ── Section — mirrors PortfolioSection sizing ────────── */
.mosaic-section {
	height: 100svh;
	display: flex;
	flex-direction: column;
	padding-top: var(--section-gap);
	padding-bottom: var(--section-gap);
	box-sizing: border-box;
}

.mosaic-shell {
	flex: 1;
	min-height: 0;
	display: flex;
	flex-direction: column;
}

.mosaic-wrap {
	flex: 1;
	min-height: 0;
	position: relative;
	overflow: visible;
	border-radius: 0;
	background: transparent;
	border: none;
	box-shadow: none;
	display: flex;
	flex-direction: column;
	padding: 0;
	gap: clamp(0.65rem, 1.2vw, 1rem);
}

/* ── Header ───────────────────────────────────────────── */

/* ── Grid ─────────────────────────────────────────────── */
.mosaic-grid {
	flex: 1;
	min-height: 0;
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	grid-template-rows: repeat(2, 1fr);
	gap: 3px;
}

/* ── Tile ─────────────────────────────────────────────── */
.mosaic-tile {
	grid-column: span var(--col);
	grid-row: span var(--row);
	position: relative;
	overflow: hidden;
	isolation: isolate;
	border-radius: 8px;
	cursor: pointer;
	border: none;
	padding: 0;
	background: transparent;
}

.mosaic-tile__bg {
	position: absolute;
	inset: 0;
	z-index: 1;
	background: var(--mosaic-tile-bg);
}

.mosaic-tile__preview {
	position: absolute;
	inset: 0;
	z-index: 2;
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
	filter: var(--mosaic-preview-filter);
	transition: filter 240ms ease;
}

.mosaic-tile.is-preview-lit .mosaic-tile__preview {
	filter: var(--mosaic-preview-filter-lit);
}

.mosaic-tile__placeholder {
	position: absolute;
	inset: 0;
	z-index: 2;
	padding: clamp(0.7rem, 1.4vw, 1rem);
	display: flex;
	align-items: flex-start;
}

.mosaic-tile__placeholder-badge {
	justify-self: start;
	align-self: start;
	padding: 0.22rem 0.55rem;
	border-radius: 999px;
	border: 1px solid color-mix(in srgb, var(--color-accent) 42%, transparent);
	background: color-mix(in srgb, var(--color-accent) 8%, transparent);
	font-size: clamp(0.68rem, 1vw, 0.82rem);
	letter-spacing: 0.12em;
	color: var(--color-accent);
	text-transform: uppercase;
}

.mosaic-tile__canvas {
	position: absolute;
	inset: 0;
	z-index: 3;
	width: 100%;
	height: 100%;
	display: block;
	pointer-events: none;
	opacity: 0.7;
}

.mosaic-tile__info {
	position: absolute;
	bottom: clamp(0.6rem, 1.2vw, 1rem);
	left: clamp(0.6rem, 1.2vw, 1rem);
	z-index: 5;
	text-align: left;
	opacity: 0;
	transform: translateY(6px);
}

.mosaic-tile__category {
	margin: 0 0 0.15rem;
	font-size: clamp(0.98rem, 1.7vw, 1.2rem);
	color: var(--mosaic-tile-muted);
	font-variant: small-caps;
	letter-spacing: 0.1em;
}

.mosaic-tile__name {
	margin: 0;
	font-size: clamp(1rem, 1.9vw, 1.35rem);
	font-weight: 500;
	color: var(--color-text);
	line-height: 1;
}

/* ── Detail overlay ───────────────────────────────────── */
.mosaic-detail {
	position: absolute;
	display: none;
	border-radius: var(--radius-card);
	overflow: hidden;
	z-index: 10;
}

.mosaic-detail__bg {
	position: absolute;
	inset: 0;
	overflow: hidden;
	background:
		radial-gradient(ellipse at 25% 35%, hsl(var(--hue) 55% 28% / 0.9) 0%, transparent 52%),
		radial-gradient(ellipse at 78% 70%, hsl(calc(var(--hue) + 45deg) 45% 22% / 0.7) 0%, transparent 48%),
		hsl(var(--hue) 12% 7%);
}

.mosaic-detail.is-placeholder-detail .mosaic-detail__bg {
	background: var(--terminal-bg);
}

.mosaic-detail.is-placeholder-detail .mosaic-detail__bg::before,
.mosaic-detail.is-placeholder-detail .mosaic-detail__bg::after {
	content: '';
	position: absolute;
	inset: clamp(1rem, 2.4vw, 2rem);
	pointer-events: none;
}

.mosaic-detail.is-placeholder-detail .mosaic-detail__bg::before {
	background:
		linear-gradient(var(--divider-subtle) 1px, transparent 1px),
		linear-gradient(90deg, var(--divider-subtle) 1px, transparent 1px),
		linear-gradient(var(--divider-accent) 1px, transparent 1px),
		linear-gradient(90deg, var(--divider-accent) 1px, transparent 1px);
	background-size:
		34px 34px,
		34px 34px,
		136px 136px,
		136px 136px;
	opacity: 0.48;
	mask-image: linear-gradient(135deg, #000 0%, rgba(0, 0, 0, 0.9) 48%, transparent 100%);
	-webkit-mask-image: linear-gradient(135deg, #000 0%, rgba(0, 0, 0, 0.9) 48%, transparent 100%);
}

.mosaic-detail.is-placeholder-detail .mosaic-detail__bg::after {
	border: 1px solid color-mix(in srgb, var(--color-accent) 24%, transparent);
	background:
		linear-gradient(var(--color-accent), var(--color-accent)) 0 0 / 42px 1px no-repeat,
		linear-gradient(var(--color-accent), var(--color-accent)) 0 0 / 1px 42px no-repeat,
		linear-gradient(var(--color-accent), var(--color-accent)) 100% 100% / 42px 1px no-repeat,
		linear-gradient(var(--color-accent), var(--color-accent)) 100% 100% / 1px 42px no-repeat;
	opacity: 0.28;
}

.mosaic-detail__overlay {
	position: absolute;
	inset: 0;
	background: var(--mosaic-detail-overlay);
}

.mosaic-detail__close {
	position: absolute;
	top: clamp(1rem, 2vw, 1.5rem);
	right: clamp(1rem, 2vw, 1.5rem);
	z-index: 3;
	background: transparent;
	border: none;
	padding: 0;
	width: 1.6rem;
	height: 1.6rem;
	display: flex;
	align-items: center;
	justify-content: center;
	cursor: pointer;
	color: var(--color-text);
	transition: color 160ms ease;
}

.mosaic-detail__close:hover {
	color: var(--color-accent);
}

.mosaic-detail__body {
	position: absolute;
	inset: 0;
	z-index: 2;
	display: flex;
	align-items: center;
}

/* ── Detail content (injected by JS) ─────────────────── */
:global(.detail-layout) {
	display: grid;
	grid-template-columns: 45% 1fr;
	gap: clamp(1rem, 2vw, 2rem);
	width: 100%;
	height: 100%;
	padding: clamp(1.5rem, 4vw, 3rem);
	box-sizing: border-box;
	align-items: center;
}

:global(.detail-text) {
	display: flex;
	flex-direction: column;
	justify-content: space-between;
	height: 100%;
	gap: clamp(0.5rem, 1vw, 0.85rem);
}

:global(.detail-text__body) {
	display: flex;
	flex-direction: column;
	gap: clamp(0.5rem, 1vw, 0.85rem);
}

:global(.detail-category) {
	margin: 0;
	font-size: clamp(1.1rem, 2vw, 1.35rem);
	color: var(--color-text-muted);
	font-variant: small-caps;
	letter-spacing: 0.12em;
}

:global(.detail-title) {
	margin: 0;
	font-size: clamp(2.4rem, 5.5vw, 5rem);
	font-weight: 600;
	line-height: 0.88;
}

:global(.detail-accent) { color: var(--color-accent); }

:global(.detail-client) {
	margin: 0;
	font-size: clamp(0.9rem, 1.6vw, 1.2rem);
	color: var(--color-text-muted);
}

:global(.detail-desc) {
	margin: 0;
	font-size: clamp(1rem, 1.7vw, 1.3rem);
	line-height: 1.3;
	color: var(--color-text);
}

:global(.detail-tags) {
	display: flex;
	flex-wrap: wrap;
	gap: 0.3rem;
}

:global(.detail-tag) {
	padding: 0.15rem 0.58rem;
	font-size: clamp(0.72rem, 1.1vw, 0.86rem);
	border: var(--chip-border);
	border-radius: 999px;
	color: var(--color-accent);
	background: var(--chip-bg);
}

:global(.detail-actions) {
	display: flex;
	align-items: baseline;
	gap: 1rem;
}

:global(.detail-cta) {
	--cta-fill-size: 0px;
	--cta-fill-target: 180px;
	--cta-fill-x: 50%;
	--cta-fill-y: 50%;
	position: relative;
	display: inline-flex;
	font-size: clamp(1.3rem, 2.4vw, 2rem);
	font-weight: 300;
	color: var(--color-text);
	white-space: nowrap;
	transition: color 180ms ease;
}

:global(.detail-cta::after) {
	content: attr(data-label);
	position: absolute;
	inset: 0;
	color: var(--color-accent);
	white-space: nowrap;
	pointer-events: none;
	mask-image: radial-gradient(
		circle var(--cta-fill-size) at var(--cta-fill-x) var(--cta-fill-y),
		#000 96%, transparent 100%
	);
	-webkit-mask-image: radial-gradient(
		circle var(--cta-fill-size) at var(--cta-fill-x) var(--cta-fill-y),
		#000 96%, transparent 100%
	);
	transition: --cta-fill-size 680ms cubic-bezier(0.22, 0.8, 0.24, 1);
}

:global(.detail-cta.is-hovered::after) {
	--cta-fill-size: var(--cta-fill-target);
}

:global(.detail-site) {
	display: inline-flex;
	align-items: center;
	gap: 0.25rem;
	font-size: clamp(0.78rem, 1.25vw, 0.94rem);
	color: var(--color-text-muted);
	transition: color 160ms ease;
}

:global(.detail-site:hover) { color: var(--color-text); }

:global(.detail-meta) {
	margin: 0;
	font-size: clamp(0.75rem, 1.2vw, 0.9rem);
	color: var(--color-text-muted);
}

:global(.detail-note) {
	margin: 0;
	font-size: clamp(0.92rem, 1.45vw, 1.05rem);
	line-height: 1.35;
	color: var(--color-accent);
}

:global(.detail-visual) {
	height: 100%;
	display: flex;
	align-items: center;
	justify-content: center;
}

:global(.detail-mockup) {
	width: 100%;
	height: 100%;
	background: var(--mosaic-detail-card-bg);
	border: 1px solid var(--mosaic-detail-card-border);
	border-radius: calc(var(--radius-card) * 0.65);
	display: flex;
	align-items: center;
	justify-content: center;
	color: var(--color-text-muted);
	font-size: clamp(0.88rem, 1.4vw, 1.05rem);
	position: relative;
	overflow: hidden;
}

:global(.detail-mockup__img) {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
}

:global(.detail-mockup--placeholder) {
	background: var(--mosaic-detail-card-bg);
}

:global(.detail-ui-terminal) {
	position: relative;
	width: 100%;
	height: 100%;
	display: grid;
	grid-template-rows: auto 1fr auto;
	border: 1px solid var(--terminal-border);
	border-radius: calc(var(--radius-card) * 0.6);
	background: linear-gradient(180deg, var(--terminal-bg) 0%, var(--terminal-bg-2) 100%);
	box-shadow:
		inset 0 1px 0 var(--terminal-inset-highlight),
		var(--terminal-shadow);
	overflow: hidden;
	font-family: 'JetBrains Mono', 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
}

:global(.detail-ui-terminal__bar) {
	position: relative;
	z-index: 1;
	display: grid;
	grid-template-columns: auto 1fr auto;
	align-items: center;
	padding: 0.7rem 1rem;
	background: var(--terminal-chrome-bg);
	border-bottom: 1px solid var(--terminal-divider);
	font-size: 0.78rem;
	color: var(--terminal-muted);
}

:global(.detail-ui-terminal__lights) {
	display: flex;
	gap: 0.45rem;
}

:global(.detail-ui-terminal__light) {
	width: 10px;
	height: 10px;
	border-radius: 999px;
	background: var(--terminal-control-bg);
}

:global(.detail-ui-terminal__light.is-active) {
	background: var(--color-accent);
	box-shadow: 0 0 10px var(--accent-glow-strong);
}

:global(.detail-ui-terminal__title) {
	text-align: center;
	font-size: 0.78rem;
	letter-spacing: 0.04em;
}

:global(.detail-ui-terminal__spacer) {
	width: 40px;
}

:global(.detail-ui-terminal__body) {
	position: relative;
	z-index: 1;
	padding: clamp(1.15rem, 2vw, 1.55rem);
	display: flex;
	flex-direction: column;
	gap: 0.72rem;
	min-height: 0;
}

:global(.detail-ui-terminal__body::before) {
	content: '';
	position: absolute;
	inset: 0;
	pointer-events: none;
	background: radial-gradient(120% 80% at 50% -20%, var(--cta-bg), transparent 60%);
}

:global(.detail-ui-terminal__cmd),
:global(.detail-ui-terminal__meta),
:global(.detail-ui-terminal__copy) {
	position: relative;
	z-index: 1;
	margin: 0;
	text-transform: none;
	letter-spacing: 0;
}

:global(.detail-ui-terminal__cmd) {
	font-size: clamp(0.92rem, 1.35vw, 1rem);
	line-height: 1.5;
	color: var(--terminal-text);
}

:global(.detail-ui-terminal__prompt) {
	color: var(--terminal-prompt);
	margin-right: 0.5ch;
}

:global(.detail-ui-terminal__sigil) {
	color: var(--color-accent);
	margin-right: 0.5ch;
}

:global(.detail-ui-terminal__copy) {
	max-width: 68ch;
	font-size: clamp(0.92rem, 1.5vw, 1.02rem);
	line-height: 1.55;
	font-weight: 400;
	color: var(--terminal-text);
	text-wrap: pretty;
}

:global(.detail-ui-terminal__copy-text) {
	display: inline;
}

:global(.detail-ui-terminal__cursor) {
	display: inline-block;
	width: 0.55ch;
	height: 1.05em;
	vertical-align: text-bottom;
	background: var(--color-accent);
	margin-left: 2px;
	animation: terminal-blink 1s steps(1, end) infinite;
}

:global(.detail-ui-terminal__copy.is-typing .detail-ui-terminal__cursor) {
	animation: none;
	opacity: 1;
}

@keyframes terminal-blink {
	0%, 50% { opacity: 1; }
	50.01%, 100% { opacity: 0; }
}

:global(.detail-ui-terminal__meta) {
	display: grid;
	gap: 0.28rem;
	margin-top: auto;
	font-size: clamp(0.82rem, 1.15vw, 0.9rem);
	line-height: 1.35;
	color: var(--terminal-muted);
}

:global(.detail-ui-terminal__meta-accent) {
	color: var(--color-accent);
}

:global(.detail-ui-terminal__status) {
	position: relative;
	z-index: 1;
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 1rem;
	padding: 0.55rem 1rem;
	background: var(--terminal-status-bg);
	border-top: 1px solid var(--terminal-divider);
	font-size: 0.78rem;
	color: var(--terminal-muted);
}

:global(.detail-ui-terminal__progress) {
	flex: 1;
	height: 6px;
	border-radius: 999px;
	background: var(--terminal-progress-bg);
	overflow: hidden;
	max-width: 60%;
}

:global(.detail-ui-terminal__progress-fill) {
	height: 100%;
	width: 68%;
	background: linear-gradient(90deg, color-mix(in srgb, var(--color-accent) 58%, transparent), var(--color-accent));
}

@media (max-width: 767px) {
	:global(.detail-ui-terminal__copy) {
		max-width: none;
	}
}

@property --cta-fill-size {
	syntax: '<length>';
	inherits: false;
	initial-value: 0px;
}

:global(html.is-mosaic-detail-open),
:global(body.is-mosaic-detail-open) {
	overflow: hidden;
	touch-action: none;
}

/* ── Mobile ───────────────────────────────────────────── */
@media (max-width: 767px) {
	.mosaic-grid {
		grid-template-columns: repeat(2, 1fr);
		grid-template-rows: repeat(4, 1fr);
	}

	.mosaic-tile {
		grid-column: span min(var(--col), 2);
		grid-row: span var(--row);
	}

	:global(.detail-layout) {
		grid-template-columns: 1fr;
	}

	:global(.detail-visual) { display: none; }
}

/* ── Reduced motion ───────────────────────────────────── */
</style>

<script>
import { getGsap } from '../../scripts/gsap';

const gsap = getGsap();

const section  = document.querySelector<HTMLElement>('#portfolio');
if (!section) throw new Error('mosaic section not found');

const wrap     = section.querySelector<HTMLElement>('.mosaic-wrap')!;
const tiles    = Array.from(section.querySelectorAll<HTMLElement>('.mosaic-tile'));
const detail   = section.querySelector<HTMLElement>('.mosaic-detail')!;
const detailBg = detail.querySelector<HTMLElement>('.mosaic-detail__bg')!;
const detailBody = detail.querySelector<HTMLElement>('.mosaic-detail__body')!;
const closeBtn = detail.querySelector<HTMLElement>('.mosaic-detail__close')!;
const detailHomeParent = detail.parentElement;

const reduceMotion = document.documentElement.classList.contains('reduce-motion');

// ── Canvas pixel engine (inverted PixelCard: idle=visible, hover=disappear) ──
	const readMosaicPixelColors = () => {
		const styles = getComputedStyle(document.documentElement);
		return Array.from({ length: 9 }, (_, index) =>
			styles.getPropertyValue(`--mosaic-pixel-${index + 1}`).trim(),
		).filter(Boolean);
	};

	let pixelColors = readMosaicPixelColors();
	const PIXEL_GAP = 4;
const PIXEL_SPEED_RAW = 42;
const effectiveSpeed = (() => {
	const throttle = 0.001;
	if (reduceMotion) return 0;
	if (PIXEL_SPEED_RAW >= 100) return 100 * throttle;
	return PIXEL_SPEED_RAW * throttle;
})();

class CanvasPixel {
	ctx: CanvasRenderingContext2D;
	x: number;
	y: number;
	color: string;
	speed: number;
	size = 0;
	sizeStep = Math.random() * 0.28 + 0.03;
	minSize = 0.45;
	maxSizeInteger = 2;
	maxSize = Math.random() * (2 - 0.85) + 0.85;
	delay: number;
	counter = 0;
	counterStep: number;
	isIdle = false;
	isReverse = false;
	isShimmer = false;

	constructor(
		ctx: CanvasRenderingContext2D,
		width: number,
		height: number,
		x: number,
		y: number,
		color: string,
		speed: number,
		delay: number,
	) {
		this.ctx = ctx;
		this.x = x;
		this.y = y;
		this.color = color;
		this.speed = (Math.random() * (0.9 - 0.1) + 0.1) * speed;
		this.delay = delay;
		this.counterStep = Math.random() * 4 + (width + height) * 0.01;
	}

	draw() {
		const centerOffset = this.maxSizeInteger * 0.5 - this.size * 0.5;
		this.ctx.fillStyle = this.color;
		this.ctx.fillRect(this.x + centerOffset, this.y + centerOffset, this.size, this.size);
	}

	appear() {
		this.isIdle = false;
		if (this.counter <= this.delay) {
			this.counter += this.counterStep;
			return;
		}
		if (this.size >= this.maxSize) {
			this.isShimmer = true;
		}
		if (this.isShimmer) {
			this.shimmer();
		} else {
			this.size += this.sizeStep;
		}
		this.draw();
	}

	disappear() {
		this.isShimmer = false;
		if (this.counter <= this.delay) {
			this.counter += this.counterStep;
			this.draw();
			return;
		}
		if (this.size <= 0) {
			this.isIdle = true;
			return;
		}
		this.size -= 0.1;
		this.draw();
	}

	shimmer() {
		if (this.size >= this.maxSize) this.isReverse = true;
		else if (this.size <= this.minSize) this.isReverse = false;
		if (this.isReverse) this.size -= this.speed;
		else this.size += this.speed;
	}
}

type TileState = {
	info: HTMLElement;
	canvas: HTMLCanvasElement;
	ctx: CanvasRenderingContext2D;
	pixels: CanvasPixel[];
	rafId: number | null;
	mode: 'appear' | 'disappear' | null;
	lastFrame: number;
};

const tileStates = new WeakMap<HTMLElement, TileState>();
let rebuildTimer: number | null = null;
let tileResizeObserver: ResizeObserver | null = null;

const mobileQuery = window.matchMedia('(max-width: 767px)');
let fullyVisibleFired = false;
let mobileTimeouts: number[] = [];
let isOpen = false;
let openedAsFullscreen = false;
const fullScreenDetailOnDesktop = true;

const getViewportSize = () => {
	const vv = window.visualViewport;
	return {
		width: vv?.width ?? window.innerWidth,
		height: vv?.height ?? window.innerHeight,
	};
};

const mountDetailToBody = () => {
	if (detail.parentElement !== document.body) {
		document.body.appendChild(detail);
	}
};

const restoreDetailParent = () => {
	if (detailHomeParent && detail.parentElement !== detailHomeParent) {
		detailHomeParent.appendChild(detail);
	}
};

const initPixels = (tile: HTMLElement) => {
	const state = tileStates.get(tile);
	if (!state) return;

	const rect = tile.getBoundingClientRect();
	const width = Math.floor(rect.width);
	const height = Math.floor(rect.height);
	if (!width || !height) return;

	state.canvas.width = width;
	state.canvas.height = height;
	state.canvas.style.width = `${width}px`;
	state.canvas.style.height = `${height}px`;

	const pxs: CanvasPixel[] = [];
	const cx = width / 2;
	const cy = height / 2;

	for (let x = 0; x < width; x += PIXEL_GAP) {
		for (let y = 0; y < height; y += PIXEL_GAP) {
				const color = pixelColors[Math.floor(Math.random() * pixelColors.length)] ?? 'currentColor';
			const dx = x - cx;
			const dy = y - cy;
			const delay = reduceMotion ? 0 : Math.sqrt(dx * dx + dy * dy);
			pxs.push(new CanvasPixel(state.ctx, width, height, x, y, color, effectiveSpeed, delay));
		}
	}
	state.pixels = pxs;
};

const stepAnimation = (state: TileState) => {
	const now = performance.now();
	const passed = now - state.lastFrame;
	const interval = 1000 / 60;
	if (passed < interval) {
		state.rafId = requestAnimationFrame(() => stepAnimation(state));
		return;
	}
	state.lastFrame = now - (passed % interval);

	state.ctx.clearRect(0, 0, state.canvas.width, state.canvas.height);

	const mode = state.mode;
	let allIdle = true;
	for (let i = 0; i < state.pixels.length; i++) {
		const p = state.pixels[i];
		if (mode === 'appear') p.appear();
		else if (mode === 'disappear') p.disappear();
		if (!p.isIdle) allIdle = false;
	}

	if (allIdle) {
		state.rafId = null;
		return;
	}
	state.rafId = requestAnimationFrame(() => stepAnimation(state));
};

const runAnimation = (tile: HTMLElement, mode: 'appear' | 'disappear') => {
	const state = tileStates.get(tile);
	if (!state) return;

	if (state.rafId !== null) {
		cancelAnimationFrame(state.rafId);
		state.rafId = null;
	}
	// reset counters so delay-waves kick off from zero on every mode switch
	for (let i = 0; i < state.pixels.length; i++) {
		state.pixels[i].counter = 0;
		state.pixels[i].isIdle = false;
	}
	state.mode = mode;
	state.lastFrame = performance.now();
	state.rafId = requestAnimationFrame(() => stepAnimation(state));
};

const resetTileVisual = (tile: HTMLElement) => {
	const state = tileStates.get(tile);
	if (!state) return;
	gsap.to(state.info, { opacity: 0, y: 6, duration: 0.18, overwrite: true });
	runAnimation(tile, 'appear');
};

tiles.forEach((tile) => {
	const info = tile.querySelector<HTMLElement>('.mosaic-tile__info');
	const canvas = tile.querySelector<HTMLCanvasElement>('.mosaic-tile__canvas');
	if (!info || !canvas) return;
	const ctx = canvas.getContext('2d');
	if (!ctx) return;

	tileStates.set(tile, {
		info,
		canvas,
		ctx,
		pixels: [],
		rafId: null,
		mode: null,
		lastFrame: 0,
	});
});

	const rebuildAll = () => {
		pixelColors = readMosaicPixelColors();
		const keepHidden = mobileQuery.matches && fullyVisibleFired;
	tiles.forEach((tile) => {
		initPixels(tile);
		if (!keepHidden) {
			// kick off idle appear so pixels are visible by default
			runAnimation(tile, 'appear');
		}
	});
};

rebuildAll();
requestAnimationFrame(() => rebuildAll());

if ('ResizeObserver' in window) {
	tileResizeObserver = new ResizeObserver(() => {
		if (rebuildTimer !== null) window.clearTimeout(rebuildTimer);
		rebuildTimer = window.setTimeout(() => {
			rebuildAll();
			rebuildTimer = null;
		}, 80);
	});
	tiles.forEach((tile) => tileResizeObserver?.observe(tile));
}

const handleResize = () => {
	if (rebuildTimer !== null) window.clearTimeout(rebuildTimer);
	rebuildTimer = window.setTimeout(() => {
		rebuildAll();
		if (isOpen && openedAsFullscreen) {
			const vp = getViewportSize();
			gsap.set(detail, { left: 0, top: 0, width: vp.width, height: vp.height });
		}
		rebuildTimer = null;
	}, 120);
};

	window.addEventListener('resize', handleResize);
	window.addEventListener('themechange', rebuildAll);

// ── Mobile: trigger shuffled disappear once section is fully visible ──
// After the first reveal, pixels never come back until page reload.
const shuffleDisappear = () => {
	const order = tiles.map((_, i) => i);
	for (let i = order.length - 1; i > 0; i -= 1) {
		const j = Math.floor(Math.random() * (i + 1));
		[order[i], order[j]] = [order[j], order[i]];
	}
	mobileTimeouts.forEach((id) => window.clearTimeout(id));
	mobileTimeouts = [];
	order.forEach((tileIndex, step) => {
		const delay = step * 140 + Math.random() * 220;
		const id = window.setTimeout(() => runAnimation(tiles[tileIndex], 'disappear'), delay);
		mobileTimeouts.push(id);
	});
};

const visibilityObserver = new IntersectionObserver(
	(entries) => {
		if (!mobileQuery.matches) return;
		const entry = entries[0];
		if (!entry || fullyVisibleFired) return;
		if (entry.intersectionRatio >= 0.95) {
			fullyVisibleFired = true;
			shuffleDisappear();
			visibilityObserver.disconnect();
		}
	},
	{ threshold: [0, 0.95, 1] },
);
visibilityObserver.observe(section);

// ── Hover ────────────────────────────────────────────────
tiles.forEach((tile) => {
	tile.addEventListener('mouseenter', () => {
		if (isOpen) return;
		if (mobileQuery.matches && fullyVisibleFired) return;
		const state = tileStates.get(tile);
		if (!state) return;

		tile.classList.add('is-preview-lit');
		runAnimation(tile, 'disappear');
		gsap.to(state.info, { opacity: 1, y: 0, duration: 0.22, overwrite: true });
		tiles.forEach((t) => {
			if (t !== tile) gsap.to(t, { opacity: 0.55, duration: 0.28, overwrite: true });
		});
	});

	tile.addEventListener('mouseleave', () => {
		if (isOpen) return;
		if (mobileQuery.matches && fullyVisibleFired) return;
		tile.classList.remove('is-preview-lit');
		resetTileVisual(tile);
		tiles.forEach((t) => {
			if (t !== tile) gsap.to(t, { opacity: 1, duration: 0.28, overwrite: true });
		});
	});

	tile.addEventListener('click', () => openDetail(tile));
});

// ── Expand ───────────────────────────────────────────────
let activeTile: HTMLElement | null = null;
let detailTypingTimer: number | null = null;

function clearDetailTyping() {
	if (detailTypingTimer !== null) {
		window.clearTimeout(detailTypingTimer);
		detailTypingTimer = null;
	}
}

function startDetailTyping() {
	clearDetailTyping();

	const typed = detailBody.querySelector<HTMLElement>('[data-detail-typed]');
	if (!typed) return;

	const fullText = typed.dataset.full ?? typed.textContent ?? '';
	const copy = typed.closest<HTMLElement>('.detail-ui-terminal__copy');

	if (reduceMotion) {
		typed.textContent = fullText;
		copy?.classList.remove('is-typing');
		return;
	}

	typed.textContent = '';
	copy?.classList.add('is-typing');

	let index = 0;

	const step = () => {
		if (!detailBody.contains(typed)) {
			clearDetailTyping();
			return;
		}

		index += 1;
		typed.textContent = fullText.slice(0, index);

		if (index >= fullText.length) {
			copy?.classList.remove('is-typing');
			detailTypingTimer = null;
			return;
		}

		detailTypingTimer = window.setTimeout(step, 16);
	};

	detailTypingTimer = window.setTimeout(step, 260);
}

function openDetail(tile: HTMLElement) {
	if (isOpen) return;
	isOpen = true;
	activeTile = tile;

	const hue = tile.dataset.hue ?? '214';
	detailBg.style.setProperty('--hue', `${hue}deg`);
	detail.classList.toggle('is-placeholder-detail', tile.dataset.placeholder === 'true');
	detailBody.innerHTML = buildDetailHTML(tile);
	setupCtaFill(detailBody);

	gsap.set([detailBody, closeBtn], { opacity: 0 });
	detail.removeAttribute('aria-hidden');
	gsap.to(tiles, { opacity: 0, duration: 0.25 });

	openedAsFullscreen = mobileQuery.matches || fullScreenDetailOnDesktop;

	const tr = tile.getBoundingClientRect();

	if (openedAsFullscreen) {
		mountDetailToBody();
		document.documentElement.classList.add('is-mosaic-detail-open');
		document.body.classList.add('is-mosaic-detail-open');
		const vp = getViewportSize();

		gsap.set(detail, {
			display: 'block',
			position: 'fixed',
			left: tr.left,
			top: tr.top,
			width: tr.width,
			height: tr.height,
			borderRadius: '8px',
			zIndex: 60,
		});

		gsap.to(detail, {
			left: 0,
			top: 0,
			width: vp.width,
			height: vp.height,
			borderRadius: 0,
			duration: 0.52,
			ease: 'power3.out',
			onComplete() {
				gsap.to(detailBody, { opacity: 1, duration: 0.32, ease: 'power2.out' });
				gsap.to(closeBtn, { opacity: 1, duration: 0.22 });
				startDetailTyping();
			},
		});
	} else {
		restoreDetailParent();
		const wr = wrap.getBoundingClientRect();

		gsap.set(detail, {
			display: 'block',
			position: 'absolute',
			left: tr.left - wr.left,
			top: tr.top - wr.top,
			width: tr.width,
			height: tr.height,
			borderRadius: '8px',
		});

		const targetRadius = getComputedStyle(wrap).borderRadius;

		gsap.to(detail, {
			left: 0, top: 0, width: '100%', height: '100%',
			borderRadius: targetRadius,
			duration: 0.52, ease: 'power3.out',
			onComplete() {
				gsap.to(detailBody, { opacity: 1, duration: 0.32, ease: 'power2.out' });
				gsap.to(closeBtn,   { opacity: 1, duration: 0.22 });
				startDetailTyping();
			},
		});
	}
}

function closeDetail() {
	if (!isOpen || !activeTile) return;

	clearDetailTyping();

	const tile = activeTile;
	gsap.to([detailBody, closeBtn], { opacity: 0, duration: 0.18 });

	const tr = tile.getBoundingClientRect();
	const tileRadius = getComputedStyle(tile).borderRadius;

	const finalize = () => {
		gsap.set(detail, {
			display: 'none',
			clearProps: 'position,zIndex,left,top,width,height,borderRadius',
		});
		restoreDetailParent();
		detail.setAttribute('aria-hidden', 'true');
		detail.classList.remove('is-placeholder-detail');
		document.documentElement.classList.remove('is-mosaic-detail-open');
		document.body.classList.remove('is-mosaic-detail-open');
		isOpen = false;
		activeTile = null;
		if (mobileQuery.matches && fullyVisibleFired) {
			tiles.forEach((t) => {
				const state = tileStates.get(t);
				if (state) gsap.to(state.info, { opacity: 0, y: 6, duration: 0.18, overwrite: true });
				t.classList.remove('is-preview-lit');
			});
		} else {
			tiles.forEach((t) => {
				t.classList.remove('is-preview-lit');
				resetTileVisual(t);
			});
		}
	};

	if (openedAsFullscreen) {
		gsap.to(detail, {
			delay: 0.12,
			left: tr.left,
			top: tr.top,
			width: tr.width,
			height: tr.height,
			borderRadius: tileRadius,
			duration: 0.42,
			ease: 'power3.in',
			onComplete: finalize,
		});
	} else {
		const wr = wrap.getBoundingClientRect();
		gsap.to(detail, {
			delay: 0.12,
			left: tr.left - wr.left,
			top: tr.top - wr.top,
			width: tr.width, height: tr.height,
			borderRadius: tileRadius,
			duration: 0.42, ease: 'power3.in',
			onComplete: finalize,
		});
	}

	gsap.to(tiles, { opacity: 1, duration: 0.35, delay: 0.15 });
}

closeBtn.addEventListener('click', closeDetail);

// Close on Escape
document.addEventListener('keydown', (e) => {
	if (e.key === 'Escape' && isOpen) closeDetail();
});

window.addEventListener(
	'pagehide',
	() => {
			window.removeEventListener('resize', handleResize);
			window.removeEventListener('themechange', rebuildAll);
		tileResizeObserver?.disconnect();
		visibilityObserver.disconnect();
		restoreDetailParent();
		document.documentElement.classList.remove('is-mosaic-detail-open');
		document.body.classList.remove('is-mosaic-detail-open');
		detail.classList.remove('is-placeholder-detail');
		clearDetailTyping();
		mobileTimeouts.forEach((id) => window.clearTimeout(id));
		mobileTimeouts = [];
		tiles.forEach((tile) => {
			const state = tileStates.get(tile);
			if (state?.rafId !== null && state?.rafId !== undefined) {
				cancelAnimationFrame(state.rafId);
				state.rafId = null;
			}
		});
		if (rebuildTimer !== null) {
			window.clearTimeout(rebuildTimer);
			rebuildTimer = null;
		}
	},
	{ once: true },
);

// ── Detail HTML builder ──────────────────────────────────
type TileMediaVariant = {
	url: string;
	width: number;
	height: number;
	format: 'webp' | 'jpeg' | 'png' | 'avif';
};

type TileMedia = {
	assetId: string;
	alt: string;
	width: number;
	height: number;
	originalUrl: string;
	variants: TileMediaVariant[];
	blurDataUrl?: string;
};

const parseTileMedia = (raw: string | undefined): TileMedia | null => {
	if (!raw) return null;
	try {
		const parsed = JSON.parse(raw) as TileMedia | null;
		if (!parsed || typeof parsed !== 'object') return null;
		if (!parsed.originalUrl || !parsed.width || !parsed.height) return null;
		return parsed;
	} catch {
		return null;
	}
};

const escapeHtml = (value: string) =>
	value
		.replaceAll('&', '&amp;')
		.replaceAll('<', '&lt;')
		.replaceAll('>', '&gt;')
		.replaceAll('"', '&quot;')
		.replaceAll("'", '&#39;');

const buildPictureHtml = (media: TileMedia, cssClass: string) => {
	const sources = media.variants
		.filter((variant) => variant.url && variant.width > 0)
		.sort((a, b) => a.width - b.width)
		.map((variant) => `${variant.url} ${variant.width}w`);
	sources.push(`${media.originalUrl} ${media.width}w`);
	const srcset = sources.join(', ');
	const alt = escapeHtml(media.alt || 'превью проекта');
	return `
		<img
			class="${cssClass}"
			src="${media.originalUrl}"
			srcset="${srcset}"
			sizes="(max-width: 767px) 100vw, 52vw"
			width="${media.width}"
			height="${media.height}"
			alt="${alt}"
			loading="lazy"
			decoding="async"
		/>`;
};

function buildDetailHTML(tile: HTMLElement): string {
	const isPlaceholder = tile.dataset.placeholder === 'true';
	const title    = escapeHtml(tile.dataset.title       ?? '');
	const category = escapeHtml(tile.dataset.category    ?? '');
	const client   = escapeHtml(
		isPlaceholder
			? 'этот слот пока свободен для следующего кейса'
			: (tile.dataset.client ?? ''),
	);
	const desc     = escapeHtml(
		isPlaceholder
			? 'здесь мог бы быть ваш проект. лендинг, магазин или веб-приложение — следующий сильный кейс может появиться именно здесь.'
			: (tile.dataset.description ?? ''),
	);
	const tags     = JSON.parse(tile.dataset.tags ?? '[]') as string[];
	const year     = escapeHtml(tile.dataset.year        ?? '');
	const dur      = escapeHtml(tile.dataset.duration    ?? '');
	const caseUrl  = escapeHtml(tile.dataset.caseUrl     ?? '#');
	const liveUrl  = escapeHtml(tile.dataset.liveUrl     ?? '#');
	const detailMedia = parseTileMedia(tile.dataset.detailMedia) ?? parseTileMedia(tile.dataset.previewMedia);
	const mockupMedia = parseTileMedia(tile.dataset.mockupMedia) ?? detailMedia;

	const [w0, ...wRest] = title.split(' ');
	const restTitle = wRest.length ? '\u00a0' + wRest.join(' ') : '';

	const tagsHtml = tags.map(t =>
		`<span class="detail-tag">${escapeHtml(t)}</span>`
	).join('');

	const visualHtml = isPlaceholder
		? `
			<div class="detail-ui-terminal">
				<div class="detail-ui-terminal__bar">
					<div class="detail-ui-terminal__lights" aria-hidden="true">
						<span class="detail-ui-terminal__light is-active"></span>
						<span class="detail-ui-terminal__light"></span>
						<span class="detail-ui-terminal__light"></span>
					</div>
					<span class="detail-ui-terminal__title">future-case.md</span>
					<span class="detail-ui-terminal__spacer" aria-hidden="true"></span>
				</div>
				<div class="detail-ui-terminal__body">
					<p class="detail-ui-terminal__cmd">
						<span class="detail-ui-terminal__prompt">~/portfolio</span>
						<span class="detail-ui-terminal__sigil">$</span>
						<span>cat future-case.md</span>
					</p>
					<p class="detail-ui-terminal__copy">
						<span class="detail-ui-terminal__copy-text" data-detail-typed data-full="здесь мог бы быть ваш проект">здесь мог бы быть ваш проект</span><span class="detail-ui-terminal__cursor" aria-hidden="true"></span>
					</p>
					<div class="detail-ui-terminal__meta">
						<span><span class="detail-ui-terminal__meta-accent">type:</span> ${category}</span>
						<span><span class="detail-ui-terminal__meta-accent">status:</span> slot open</span>
						<span><span class="detail-ui-terminal__meta-accent">next:</span> этот кейс может стать вашим</span>
					</div>
				</div>
				<div class="detail-ui-terminal__status">
					<span>slot 01/01</span>
				</div>
			</div>`
		: mockupMedia
		? `<div class="detail-mockup">${buildPictureHtml(mockupMedia, 'detail-mockup__img')}</div>`
		: '<div class="detail-mockup">мокап проекта</div>';

	const actionsHtml = isPlaceholder
		? '<p class="detail-note">ваш будущий проект может занять этот слот.</p>'
		: `
			<div class="detail-actions">
				<a href="${caseUrl}" class="detail-cta"
				   data-cta-fill data-label="подробный кейс">подробный кейс</a>
				<a href="${liveUrl}" class="detail-site"
				   target="_blank" rel="noopener noreferrer">
					открыть сайт
					<svg width="10" height="10" viewBox="0 0 10 10" fill="none">
						<path d="M1 9L9 1M9 1H3.5M9 1V6.5"
							stroke="currentColor" stroke-width="1.5"
							stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>`;

	return `
		<div class="detail-layout">
			<div class="detail-text">
				<p class="detail-category">${category}</p>
				<div class="detail-text__body">
					<h2 class="detail-title">
						<span class="detail-accent">${w0}</span>${restTitle}
					</h2>
					<p class="detail-client">${client}</p>
					<p class="detail-desc">${desc}</p>
					<div class="detail-tags">${tagsHtml}</div>
					${actionsHtml}
					<p class="detail-meta">${year} · ${dur}</p>
				</div>
			</div>
			<div class="detail-visual">
				${visualHtml}
			</div>
		</div>`;
}

// ── CTA fill effect ──────────────────────────────────────
function setupCtaFill(root: HTMLElement) {
	root.querySelectorAll<HTMLElement>('[data-cta-fill]').forEach(link => {
		link.addEventListener('pointerenter', (e: PointerEvent) => {
			const rect = link.getBoundingClientRect();
			const lx = Math.max(0, Math.min(rect.width,  e.clientX - rect.left));
			const ly = Math.max(0, Math.min(rect.height, e.clientY - rect.top));
			const maxR = Math.max(...[
				[0, 0], [rect.width, 0],
				[0, rect.height], [rect.width, rect.height],
			].map(([cx, cy]) => Math.hypot((cx as number) - lx, (cy as number) - ly)));
			link.style.setProperty('--cta-fill-x', `${(lx / rect.width) * 100}%`);
			link.style.setProperty('--cta-fill-y', `${(ly / rect.height) * 100}%`);
			link.style.setProperty('--cta-fill-target', `${Math.ceil(maxR + 8)}px`);
			link.classList.add('is-hovered');
		});
		link.addEventListener('pointerleave', () => link.classList.remove('is-hovered'));
	});
}
</script>
