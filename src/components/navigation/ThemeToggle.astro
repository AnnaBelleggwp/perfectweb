---
---

<button class="theme-toggle" type="button" data-theme-toggle aria-label="переключить тему">
	<span class="theme-toggle__track" aria-hidden="true">
		<svg class="theme-toggle__icon theme-toggle__icon--sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
			<circle cx="12" cy="12" r="4" />
			<path d="M12 3v2" />
			<path d="M12 19v2" />
			<path d="M3 12h2" />
			<path d="M19 12h2" />
			<path d="M5.6 5.6l1.4 1.4" />
			<path d="M17 17l1.4 1.4" />
			<path d="M5.6 18.4l1.4-1.4" />
			<path d="M17 7l1.4-1.4" />
		</svg>
		<svg class="theme-toggle__icon theme-toggle__icon--moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
			<path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z" />
		</svg>
	</span>
</button>

<style>
.theme-toggle {
	position: fixed;
	right: clamp(1rem, 2.4vw, 1.6rem);
	bottom: clamp(1rem, 2.4vw, 1.6rem);
	z-index: 50;
	width: 44px;
	height: 44px;
	padding: 0;
	border: none;
	background: transparent;
	color: var(--color-text);
	cursor: pointer;
	display: inline-flex;
	align-items: center;
	justify-content: center;
	opacity: 0;
	visibility: hidden;
	pointer-events: none;
	transition:
		color 200ms ease,
		transform 200ms ease,
		opacity 280ms ease,
		visibility 0s linear 280ms;
}

.theme-toggle.is-revealed {
	opacity: 1;
	visibility: visible;
	pointer-events: auto;
	transition:
		color 200ms ease,
		transform 200ms ease,
		opacity 280ms ease,
		visibility 0s linear 0s;
}

.theme-toggle:hover,
.theme-toggle:focus-visible {
	outline: none;
	color: var(--color-accent);
	transform: translateY(-1px);
}

.theme-toggle__track {
	position: relative;
	width: 22px;
	height: 22px;
	display: block;
}

.theme-toggle__icon {
	position: absolute;
	inset: 0;
	width: 100%;
	height: 100%;
	transition:
		opacity 220ms ease,
		transform 280ms cubic-bezier(0.22, 0.8, 0.24, 1);
}

.theme-toggle__icon--sun {
	opacity: 1;
	transform: scale(1) rotate(0);
}

.theme-toggle__icon--moon {
	opacity: 0;
	transform: scale(0.6) rotate(-60deg);
}

:root[data-theme="light"] .theme-toggle__icon--sun {
	opacity: 0;
	transform: scale(0.6) rotate(60deg);
}

:root[data-theme="light"] .theme-toggle__icon--moon {
	opacity: 1;
	transform: scale(1) rotate(0);
}

@media (prefers-reduced-motion: reduce) {
	.theme-toggle,
	.theme-toggle__icon {
		transition: none;
	}
}
</style>

<script>
	const button = document.querySelector<HTMLElement>('[data-theme-toggle]');
	const about = document.querySelector('#about');
	const footer = document.querySelector('[data-footer-term]');
	if (button && about) {
		let aboutVisible = false;
		let footerVisible = false;

		const update = () => {
			button.classList.toggle('is-revealed', aboutVisible && !footerVisible);
		};

		const aboutIo = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					aboutVisible = entry.isIntersecting || entry.boundingClientRect.top < 0;
				}
				update();
			},
			{ rootMargin: '0px 0px -10% 0px', threshold: 0 },
		);
		aboutIo.observe(about);

		if (footer) {
			const footerIo = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						footerVisible = entry.isIntersecting;
					}
					update();
				},
				{ threshold: 0 },
			);
			footerIo.observe(footer);
		}
	}
</script>
